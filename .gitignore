node_modules/
dist/
build/
.env
.env.local
*.log
.DS_Store
coverage/
.vite/
.turbo/
generated/

# astro build cache (only the root .gitignore is used; inner workspaces inherit)
.astro/

# tsbuild incremental cache
*.tsbuildinfo

# npm lockfiles (pnpm-lock.yaml is the source of truth)
package-lock.json
**/package-lock.json
# ...except duncit-mobile-app, a standalone npm app (EAS needs its lockfile to pick npm)
!duncit-mobile-app/package-lock.json
# ...and open-wa-server (+ its bundled dashboard SPA): its Docker build runs
# `npm ci` for both, so both lockfiles must be committed.
!portals/crm/open-wa-server/package-lock.json
!portals/crm/open-wa-server/dashboard/package-lock.json
# Local SonarQube issue dumps (pnpm sonar:issues)
sonar-issues.json
sonar-issues.md
