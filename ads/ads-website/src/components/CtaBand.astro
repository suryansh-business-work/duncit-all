---
import { siteConfig } from '../config/site-config';
const { cta } = siteConfig;
---

<section class="mx-auto max-w-6xl px-5 py-16">
  <div class="rounded-3xl bg-ink px-8 py-14 text-center text-white sm:px-16">
    <h2 class="mx-auto max-w-2xl text-3xl text-white sm:text-4xl">{cta.heading}</h2>
    <p class="mx-auto mt-4 max-w-xl text-white/70">{cta.text}</p>
    <a
      href={cta.button.href}
      class="mt-8 inline-block rounded-full bg-primary px-8 py-3 text-base font-bold text-white transition hover:bg-primary-dark"
    >
      {cta.button.label}
    </a>
  </div>
</section>
