---
import { siteConfig } from '../config/site-config';
const { features } = siteConfig;
---

<section id="features" class="mx-auto max-w-6xl scroll-mt-20 px-5 py-16">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl text-ink sm:text-4xl">Everything you need to run ads</h2>
    <p class="mt-4 text-ink-soft">One console for the full campaign lifecycle.</p>
  </div>
  <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {
      features.map((feature) => (
        <article class="rounded-2xl border border-black/5 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
          <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-light text-primary-dark">
            <i class={`fa-solid ${feature.icon} text-xl`} aria-hidden="true"></i>
          </span>
          <h3 class="mt-5 text-lg text-ink">{feature.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">{feature.text}</p>
        </article>
      ))
    }
  </div>
</section>
