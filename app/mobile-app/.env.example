# Duncit mobile app (Expo). EXPO_PUBLIC_* vars are inlined into the bundle.
# Release builds load .env.production; a Metro host wins for on-device dev.

# API base. A non-loopback value always wins (release builds).
EXPO_PUBLIC_API_URL=https://server.duncit.com

# Google OAuth client id + Maps key (secrets — set in your local env / EAS).
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_MAP_API=
