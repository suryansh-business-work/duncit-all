{
  "expo": {
    "name": "Duncit",
    "slug": "duncit-mobile",
    "version": "1.3.19",
    "orientation": "portrait",
    "scheme": "duncit",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/duncit-logo.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.duncit.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow location access to fetch your current coordinates.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.duncit.mobile",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/duncit-icon-foreground.png",
        "backgroundColor": "#F82C2E"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/duncit-logo.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/duncit-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#F82C2E"
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Duncit to access your photos to post a status."
        }
      ],
      "expo-document-picker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Duncit to use your location."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#F82C2E"
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "useLegacyPackaging": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "./plugins/withNdkVersion",
      "expo-web-browser",
      "expo-video"
    ],
    "owner": "duncit",
    "extra": {
      "eas": {
        "projectId": "d65e65ee-fabe-4605-b412-96a6313321d9"
      }
    }
  }
}
