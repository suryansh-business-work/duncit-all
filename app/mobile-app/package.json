{
  "name": "duncit-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start --port 2022",
    "android": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start --android --port 2022",
    "ios": "expo start --ios --port 2022",
    "web": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start --web --port 2022",
    "export:web": "expo export --platform web --output-dir dist",
    "prebuild": "expo prebuild",
    "codegen": "graphql-codegen --config codegen.ts",
    "eas-build-post-install": "npm run codegen",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e:build": "detox build --configuration android.emu.debug",
    "e2e:test": "detox test --configuration android.emu.debug",
    "test:e2e:web": "playwright test --config=e2e-web/playwright.config.ts",
    "test:e2e:web:ui": "playwright test --config=e2e-web/playwright.config.ts --ui",
    "build:android:apk": "eas build --platform android --profile preview --non-interactive",
    "build:android:aab": "eas build --platform android --profile production --non-interactive",
    "build:ios": "eas build --platform ios --profile production",
    "build:local:apk": "node scripts/build-local-android.js",
    "build:local:aab": "node scripts/build-local-android.js --aab",
    "build:local:ios": "node scripts/build-local-ios.js",
    "upload:slack": "node scripts/upload-slack.js",
    "ci": "npm run test:coverage && npm run typecheck && npm run lint"
  },
  "dependencies": {
    "@duncit/auth-tokens": "file:../../packages/auth-tokens",
    "@duncit/logs": "file:../../packages/logs",
    "@expo/vector-icons": "^15.0.3",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@hookform/resolvers": "^3.9.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@tamagui/config": "^2.1.0",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "expo": "^54.0.35",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-manipulator": "~14.0.7",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.11",
    "graphql": "^16.14.1",
    "graphql-request": "^6.1.0",
    "lottie-react-native": "~7.3.1",
    "moti": "^0.30.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.54.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-refresh": "^0.18.0",
    "socket.io-client": "^4.8.3",
    "tamagui": "^2.1.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/client-preset": "^4.8.3",
    "@playwright/test": "^1.60.0",
    "@slack/web-api": "^7.8.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.17",
    "babel-preset-expo": "~54.0.11",
    "cross-env": "^10.1.0",
    "detox": "^20.28.0",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "prettier": "^3.4.2",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
