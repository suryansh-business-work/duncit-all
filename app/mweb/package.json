{
  "name": "mweb-app",
  "version": "1.5.11",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:main": "cross-env VITE_GRAPHQL_URL=https://server.duncit.com/graphql vite",
    "dev:staging": "cross-env VITE_GRAPHQL_URL=https://staging.server.duncit.com/graphql vite",
    "dev:local:main": "cross-env VITE_GRAPHQL_URL=http://localhost:2001/graphql vite",
    "dev:local:staging": "cross-env VITE_GRAPHQL_URL=http://localhost:2001/graphql vite",
    "dev:force": "vite --force",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:forms": "vitest run",
    "test:forms:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@apollo/client": "^3.10.4",
    "@duncit/auth-tokens": "workspace:*",
    "@duncit/geo": "workspace:*",
    "@duncit/location": "workspace:*",
    "@duncit/ui": "workspace:*",
    "@duncit/logs": "workspace:*",
    "@duncit/media-picker": "workspace:*",
    "@duncit/regex": "workspace:*",
    "@duncit/user-context": "workspace:*",
    "@duncit/utils": "workspace:*",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@fontsource-variable/quicksand": "^5.1.1",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@hookform/resolvers": "^3.9.1",
    "@mui/icons-material": "^5.15.18",
    "@mui/material": "^5.15.18",
    "@mui/system": "^5.15.18",
    "@mui/x-charts": "^6",
    "@mui/x-date-pickers": "^6.20.2",
    "@react-oauth/google": "^0.13.5",
    "countries-list": "^3.3.0",
    "country-region-data": "^4.1.0",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.1",
    "formik": "^2.4.6",
    "graphql": "^16.8.1",
    "lottie-react": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.0.8",
    "react-hook-form": "^7.54.0",
    "react-quill": "^2.0.0",
    "react-router": "^6.23.1",
    "react-router-dom": "^6.23.1",
    "react-slick": "^0.31.0",
    "slick-carousel": "^1.8.1",
    "socket.io-client": "^4.8.3",
    "yup": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-slick": "^0.23.13",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^24.1.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.1"
  }
}
