# Public API base URL consumed by the app at runtime (origin only — the GraphQL
# client appends `/graphql`). Local dev API runs on port 2001; Expo dev server
# runs on 2022. Production/release builds use .env.production (server.duncit.com).
EXPO_PUBLIC_API_URL=http://localhost:2001

# Slack upload (used by scripts/upload-slack.js and CI only, never bundled).
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Expo / EAS automation token (CI only).
EXPO_TOKEN=

# Apple credentials for iOS EAS builds (CI only).
APPLE_ID=
APPLE_TEAM_ID=

# Google sign-in (Expo web + native). Use the SAME Web OAuth client ID as mWeb
# (VITE_GOOGLE_CLIENT_ID) and the server (Tech portal GOOGLE_OAUTH → Client ID).
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_web_oauth_client_id.apps.googleusercontent.com
# Google Maps key for the location picker / map embed.
EXPO_PUBLIC_GOOGLE_MAP_API=your_google_maps_api_key_here
