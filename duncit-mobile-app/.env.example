# Public API base URL consumed by the app at runtime.
# Important duncit dev ports: 2020 (API) and 2021 (Expo dev server).
EXPO_PUBLIC_API_URL=http://localhost:2020

# Slack upload (used by scripts/upload-slack.js and CI only, never bundled).
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Expo / EAS automation token (CI only).
EXPO_TOKEN=

# Apple credentials for iOS EAS builds (CI only).
APPLE_ID=
APPLE_TEAM_ID=
