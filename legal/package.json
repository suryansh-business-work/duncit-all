{
  "name": "legal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:e2e": "tsc -b && vite build --mode e2e",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cypress run --config-file __tests__/e2e/cypress.config.ts",
    "test:e2e:open": "cypress open --config-file __tests__/e2e/cypress.config.ts",
    "test:forms": "vitest run",
    "test:forms:watch": "vitest"
  },
  "dependencies": {
    "@duncit/user-context": "workspace:*",
    "@apollo/client": "^3.10.4",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.18",
    "@mui/material": "^5.15.18",
    "@mui/system": "^5.15.18",
    "@mui/x-date-pickers": "^6.20.2",
    "@react-oauth/google": "^0.13.5",
    "date-fns": "^2.30.0",
    "formik": "^2.4.6",
    "graphql": "^16.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-quill": "^2.0.0",
    "react-router": "^6.23.1",
    "react-router-dom": "^6.23.1",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.6.1",
    "cypress": "^15.16.0",
    "jsdom": "^24.1.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.1"
  }
}
