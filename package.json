{
  "name": "duncit",
  "version": "1.0.0",
  "private": true,
  "description": "Full Stack Monorepo (React + GraphQL + Node.js)",
  "workspaces": [
    "server",
    "web-ui/app",
    "web-ui/admin"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:app": "npm run dev --workspace=app",
    "dev:admin": "npm run dev --workspace=admin",
    "build": "npm run build --workspaces --if-present",
    "codegen": "npm run codegen --workspace=server"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
