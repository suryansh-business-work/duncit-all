{
  "name": "duncit",
  "version": "1.0.0",
  "private": true,
  "description": "Full Stack Monorepo (React + GraphQL + Node.js)",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:server": "pnpm --filter server dev",
    "dev:app": "pnpm --filter mweb-app dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:website": "pnpm --filter duncit.com dev",
    "dev:partners-app": "pnpm --filter partners-app dev",
    "dev:partners-website": "pnpm --filter partners-website dev",
    "dev:ads-portal": "pnpm --filter ads-portal dev",
    "dev:ads-website": "pnpm --filter ads-website dev",
    "dev:crm": "pnpm --filter crm dev",
    "dev:finance": "pnpm --filter finance dev",
    "dev:tech": "pnpm --filter tech dev",
    "dev:support": "pnpm --filter support dev",
    "dev:website-app": "pnpm --filter website-app dev",
    "dev:legal": "pnpm --filter legal dev",
    "dev:ai": "pnpm --filter ai dev",
    "dev:products": "pnpm --filter products dev",
    "clear-branch": "git branch | grep -v \"main\" | grep -v \"staging\" | xargs git branch -D",
    "dev:marketing": "pnpm --filter marketing dev",
    "dev:onboarding": "pnpm --filter onboarding dev",
    "dev:hr": "pnpm --filter hr dev",
    "dev:employee": "pnpm --filter employee dev",
    "dev:status": "pnpm --filter status dev",
    "dev:earnwith": "pnpm --filter earnwith-website dev",
    "dev:challenge": "pnpm --filter challenge-portal dev",
    "dev:developers": "pnpm --filter developers-portal dev",
    "run:all": "pnpm kill-ports:all && node scripts/dev-banner.mjs",
    "kill-ports:all": "node scripts/kill-ports.mjs",
    "build": "pnpm --recursive --if-present build",
    "build:server": "pnpm --filter server build",
    "build:app": "pnpm --filter mweb-app build",
    "build:admin": "pnpm --filter admin build",
    "build:website": "pnpm --filter duncit.com build",
    "build:partners-app": "pnpm --filter partners-app build",
    "build:partners-website": "pnpm --filter partners-website build",
    "build:ads-portal": "pnpm --filter ads-portal build",
    "build:ads-website": "pnpm --filter ads-website build",
    "build:crm": "pnpm --filter crm build",
    "build:finance": "pnpm --filter finance build",
    "build:tech": "pnpm --filter tech build",
    "build:support": "pnpm --filter support build",
    "build:website-app": "pnpm --filter website-app build",
    "build:legal": "pnpm --filter legal build",
    "build:ai": "pnpm --filter ai build",
    "build:products": "pnpm --filter products build",
    "build:marketing": "pnpm --filter marketing build",
    "build:onboarding": "pnpm --filter onboarding build",
    "build:hr": "pnpm --filter hr build",
    "build:employee": "pnpm --filter employee build",
    "build:status": "pnpm --filter status build",
    "build:earnwith": "pnpm --filter earnwith-website build",
    "build:challenge": "pnpm --filter challenge-portal build",
    "build:developers": "pnpm --filter developers-portal build",
    "typecheck": "pnpm --recursive --if-present build",
    "test:forms": "pnpm --filter admin test:forms && pnpm --filter mweb-app test:forms && pnpm --filter ads-portal test:forms && pnpm --filter crm test:forms && pnpm --filter finance test:forms && pnpm --filter tech test:forms && pnpm --filter support test:forms && pnpm --filter website-app test:forms && pnpm --filter legal test:forms && pnpm --filter ai test:forms && pnpm --filter products test:forms && pnpm --filter marketing test:forms && pnpm --filter onboarding test:forms && pnpm --filter hr test:forms && pnpm --filter employee test:forms && pnpm --filter challenge-portal test:forms && pnpm --filter developers-portal test:forms",
    "test:forms:admin": "pnpm --filter admin test:forms",
    "test:forms:mweb": "pnpm --filter mweb-app test:forms",
    "test:forms:ads-portal": "pnpm --filter ads-portal test:forms",
    "test:forms:crm": "pnpm --filter crm test:forms",
    "test:forms:finance": "pnpm --filter finance test:forms",
    "test:forms:tech": "pnpm --filter tech test:forms",
    "test:forms:support": "pnpm --filter support test:forms",
    "test:forms:website-app": "pnpm --filter website-app test:forms",
    "test:forms:legal": "pnpm --filter legal test:forms",
    "test:forms:ai": "pnpm --filter ai test:forms",
    "test:forms:products": "pnpm --filter products test:forms",
    "test:forms:marketing": "pnpm --filter marketing test:forms",
    "codegen": "pnpm --filter server codegen",
    "graphql:sync": "pnpm codegen",
    "graphql:sync:watch": "pnpm --filter server codegen:watch",
    "coverage": "node scripts/coverage-report.mjs",
    "coverage:json": "node scripts/coverage-report.mjs --json",
    "mobile:install": "cd app/mobile-app && npm install",
    "dev:mobile": "cd app/mobile-app && npm run start",
    "mobile:android": "cd app/mobile-app && npm run android",
    "mobile:ios": "cd app/mobile-app && npm run ios",
    "mobile:web": "cd app/mobile-app && npm run web",
    "mobile:prebuild": "cd app/mobile-app && npm run prebuild",
    "mobile:lint": "cd app/mobile-app && npm run lint",
    "mobile:lint:fix": "cd app/mobile-app && npm run lint:fix",
    "mobile:format": "cd app/mobile-app && npm run format",
    "mobile:typecheck": "cd app/mobile-app && npm run typecheck",
    "mobile:test": "cd app/mobile-app && npm run test",
    "mobile:test:coverage": "cd app/mobile-app && npm run test:coverage",
    "mobile:e2e:build": "cd app/mobile-app && npm run e2e:build",
    "mobile:e2e:test": "cd app/mobile-app && npm run e2e:test",
    "mobile:build:apk": "cd app/mobile-app && npm run build:android:apk",
    "mobile:build:aab": "cd app/mobile-app && npm run build:android:aab",
    "mobile:build:apk:local": "cd app/mobile-app/android && gradlew.bat assembleRelease",
    "mobile:build:aab:local": "cd app/mobile-app/android && gradlew.bat bundleRelease",
    "mobile:build:ios": "cd app/mobile-app && npm run build:ios",
    "mobile:upload:slack": "cd app/mobile-app && npm run upload:slack",
    "mobile:ci": "cd app/mobile-app && npm run ci",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": []
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "mongodb-memory-server"
    ],
    "overrides": {
      "@mui/x-date-pickers>date-fns": "2.30.0"
    }
  }
}
