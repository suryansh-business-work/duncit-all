{
  "name": "duncit",
  "version": "1.0.0",
  "private": true,
  "description": "Full Stack Monorepo (React + GraphQL + Node.js)",
  "workspaces": [
    "server",
    "mweb-app",
    "admin",
    "website"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:app": "npm run dev --workspace=mweb-app",
    "dev:admin": "npm run dev --workspace=admin",
    "dev:website": "npm run dev --workspace=website",
    "build": "npm run build --workspaces --if-present",
    "build:server": "npm run build --workspace=server",
    "build:app": "npm run build --workspace=mweb-app",
    "build:admin": "npm run build --workspace=admin",
    "build:website": "npm run build --workspace=website",
    "typecheck": "npm run build --workspaces --if-present",
    "test:forms": "npm run test:forms --workspace=admin && npm run test:forms --workspace=mweb-app",
    "test:forms:admin": "npm run test:forms --workspace=admin",
    "test:forms:mweb": "npm run test:forms --workspace=mweb-app",
    "codegen": "npm run codegen --workspace=server",
    "graphql:sync": "npm run codegen",
    "graphql:sync:watch": "npm run codegen:watch --workspace=server",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": []
  }
}
