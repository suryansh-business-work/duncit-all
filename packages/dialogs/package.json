{
  "name": "@duncit/dialogs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared MUI dialog primitives for every portal: ConfirmDialog (superset of all portal variants), promise-based ConfirmProvider/useConfirm, and the imperative notify()/NotifyHost snackbar with NotifyProvider/useNotify. Replaces window.confirm/alert (CLAUDE rule 12).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@mui/material": ">=5",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@mui/material": "^5.15.18",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
