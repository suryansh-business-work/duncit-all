{
  "name": "@duncit/logs",
  "version": "1.0.0",
  "private": true,
  "description": "Global structured logger shipped to SignOz — logs.<app>.<level>(page, component, object).",
  "main": "./dist/index.js",
  "module": "./src/index.ts",
  "react-native": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
