{
  "name": "@duncit/media-picker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared ImageKit + Pexels media picker dialog (device upload, Pexels photos, Pexels videos) used by mWeb and every portal. One copy, not six.",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@apollo/client": ">=3",
    "@mui/icons-material": ">=5",
    "@mui/material": ">=5",
    "graphql": ">=16",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@apollo/client": "^3.10.4",
    "@mui/icons-material": "^5.15.18",
    "@mui/material": "^5.15.18",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "graphql": "^16.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9",
    "jsdom": "^25.0.1",
    "@vitest/coverage-v8": "^2.1.9"
  }
}
