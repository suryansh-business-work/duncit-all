# Duncit Partners App (dev port 2005)
#
# All Duncit web apps share the same env shape. Local dev does NOT need this
# file — `vite dev` automatically routes to http://localhost:2001/graphql.
# Set these only when you need to override the defaults or enable Google login.

# Shared OAuth — same client ID across every Duncit web app.
VITE_GOOGLE_CLIENT_ID=your_client_id_here

# Optional URL overrides (default: localhost in dev, production in build).
# VITE_GRAPHQL_URL=
# VITE_PARTNERS_APP_URL=
# VITE_MWEB_URL=

# Google Maps key used by venue map previews.
VITE_GOOGLE_MAP_API=your_google_maps_api_key_here
