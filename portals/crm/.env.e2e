# Loaded by `vite build --mode e2e` (via `pnpm build:e2e`). Forces the CRM
# bundle to talk to a same-origin `/graphql` so Cypress's `cy.intercept()`
# always catches the request — no cross-origin CORS preflight, no real
# network hop to server.duncit.com.
VITE_GRAPHQL_URL=/graphql
CYPRESS_TEST_EMAIL=admin@duncit.com
CYPRESS_TEST_PASSWORD=12345678