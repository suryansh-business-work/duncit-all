# Duncit OpenWA WhatsApp gateway (dev port 2024). Rendered to
# /opt/duncit/open-wa.env by the deploy workflow in production.
NODE_ENV=development
PORT=2024
DATABASE_TYPE=sqlite
DATABASE_NAME=./data/openwa.sqlite
SESSION_DATA_PATH=./data/sessions
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/media

# Bootstraps the gateway's own API keys (secret).
API_MASTER_KEY=
