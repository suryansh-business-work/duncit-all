{
  "name": "crm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:e2e": "tsc -b && vite build --mode e2e",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:open": "vitest run --coverage && start cypress-artifacts/coverage/index.html",
    "test:e2e": "cypress run --config-file __tests__/e2e/cypress.config.ts",
    "test:e2e:open": "cypress open --config-file __tests__/e2e/cypress.config.ts",
    "test:forms": "vitest run",
    "test:forms:watch": "vitest",
    "test:pw": "playwright test",
    "test:pw:ui": "playwright test --ui",
    "coverage:report": "nyc report --reporter=text --reporter=html --reporter=text-summary",
    "coverage:check": "nyc check-coverage",
    "coverage:all": "playwright test && vitest run --coverage --config vitest.coverage.config.ts && node scripts/merge-coverage.mjs && nyc report --reporter=text --reporter=text-summary && nyc check-coverage"
  },
  "dependencies": {
    "@apollo/client": "^3.10.4",
    "@duncit/app-settings": "workspace:*",
    "@duncit/dialogs": "workspace:*",
    "@duncit/forms": "workspace:*",
    "@duncit/location": "workspace:*",
    "@duncit/logs": "workspace:*",
    "@duncit/media-picker": "workspace:*",
    "@duncit/shell": "workspace:*",
    "@duncit/table": "workspace:*",
    "@duncit/theme": "workspace:*",
    "@duncit/ui": "workspace:*",
    "@duncit/user-context": "workspace:*",
    "@duncit/utils": "workspace:*",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@hookform/resolvers": "^3.9.1",
    "@monaco-editor/react": "^4.6.0",
    "@mui/icons-material": "^5.15.18",
    "@mui/material": "^5.15.18",
    "@mui/system": "^5.15.18",
    "@mui/x-data-grid": "^7.5.1",
    "@mui/x-date-pickers": "^6.20.2",
    "@react-oauth/google": "^0.13.5",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@wavesurfer/react": "^1.0.12",
    "ag-grid-community": "^34.3.1",
    "ag-grid-react": "^34.3.1",
    "chart.js": "^4.5.1",
    "date-fns": "^2.30.0",
    "graphql": "^16.8.1",
    "lottie-react": "^2.4.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "react-router": "^6.23.1",
    "react-router-dom": "^6.23.1",
    "socket.io-client": "^4.8.3",
    "wavesurfer.js": "^7.12.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-istanbul": "1.6.1",
    "@vitest/coverage-v8": "^1.6.1",
    "cypress": "^15.16.0",
    "jsdom": "^24.1.3",
    "nyc": "^18.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-istanbul": "6.0.2",
    "vitest": "^1.6.1"
  }
}
