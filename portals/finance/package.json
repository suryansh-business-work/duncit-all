{
  "name": "finance",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:forms": "vitest run",
    "test:forms:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "coverage:report": "nyc report --reporter=text --reporter=html --reporter=text-summary",
    "coverage:check": "nyc check-coverage",
    "test:e2e:coverage": "playwright test && nyc report --reporter=text-summary && nyc check-coverage",
    "coverage:all": "playwright test && vitest run --coverage && node scripts/merge-coverage.mjs && nyc report --reporter=text --reporter=text-summary && nyc check-coverage",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@apollo/client": "^3.10.4",
    "@duncit/logs": "workspace:*",
    "@duncit/theme": "workspace:*",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@hookform/resolvers": "^3.9.1",
    "@mui/icons-material": "^5.15.18",
    "@mui/material": "^5.15.18",
    "@mui/system": "^5.15.18",
    "@mui/x-date-pickers": "^6.20.2",
    "@react-oauth/google": "^0.13.5",
    "ag-grid-community": "^34.3.1",
    "ag-grid-react": "^34.3.1",
    "date-fns": "^2.30.0",
    "graphql": "^16.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "react-router": "^6.23.1",
    "react-router-dom": "^6.23.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-istanbul": "1.6.1",
    "jsdom": "^24.1.3",
    "nyc": "^18.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-istanbul": "^6.0.2",
    "vitest": "^1.6.1"
  }
}
