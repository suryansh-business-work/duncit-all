# Duncit Legal (dev port 2012)
#
# Every Duncit web app shares the same env shape. Local `vite dev` needs NONE
# of these — it defaults to http://localhost:2001/graphql. CI injects the
# real values at build time; .env.staging / .env.production hold the
# non-secret URLs for local `vite build --mode staging|production`.

# API endpoint. Empty = dev localhost / build-time production default.
VITE_GRAPHQL_URL=

# Shared Google OAuth client id (secret — injected by CI, blank locally).
VITE_GOOGLE_CLIENT_ID=

# Google Maps key for location pickers / map previews (secret — CI-injected).
VITE_GOOGLE_MAP_API=

# Roles allowed into this console (SUPER_ADMIN always passes).
VITE_REQUIRED_ROLES=LEGAL_MANAGER
