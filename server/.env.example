# Duncit Server (port 2001)
#
# This lists ONLY the values the server reads from process.env. All managed
# service credentials (SMTP / ImageKit / Pexels / Google / OpenAI / Twilio /
# Razorpay / ShipRocket / Servam) are configured in the Tech portal and
# resolved from the database at runtime — see the note at the bottom.
#
# Production/staging server.env is rendered by the deploy workflow from GitHub
# secrets; there is intentionally no committed .env.production / .env.staging.

# ---- Core (required) ----
NODE_ENV=development
PORT=2001
MONGO_URI=
JWT_SECRET=change-me-in-production

# ---- Deployment identity ----
# APP_ENV self-identifies the deployment (health, telemetry, staging-aware
# status probes). MONGO_DB_NAME overrides the database — staging uses
# duncit-staging so its data is fully separate from production.
# APP_ENV=production
# MONGO_DB_NAME=

# ---- Runtime URL/config (unmapped keys, read from process.env) ----
IS_DEVELOPMENT=true
SERVER_URL=http://localhost:2001
GRAPHQL_URL=http://localhost:2001/graphql
MWEB_BASE_URL=http://localhost:2003
PUBLIC_APP_URL=http://localhost:2003
PUBLIC_SITE_URL=http://localhost:2000

# ---- OpenWA gateway + telemetry ----
OPENWA_API_MASTER_KEY=
# OPENWA_INTERNAL_URL=http://open-wa:2024
# OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-otel-collector:4318
# OTEL_SERVICE_NAME=duncit-server

# ---- Super-admin bootstrap (created on first boot if missing) ----
DEFAULT_SUPER_ADMIN_EMAIL=admin@duncit.com
DEFAULT_SUPER_ADMIN_PASSWORD=12345678

# ---- Status page ----
# STATUS_PROBES_DISABLED=1 turns off the 5-minute prober.
# STATUS_SEED_INCIDENTS=1 seeds sample incidents (auto-on for staging).

# ---- Optional ----
# NGROK_AUTHTOKEN=

# =====================================================================
# MANAGED IN THE TECH PORTAL — DO NOT set these here (read from the DB):
#   SMTP_HOST/PORT/USER/PASS/FROM, IMAGEKIT_PUBLIC_KEY/PRIVATE_KEY/URL_ENDPOINT,
#   PEXELS_API_KEY, GOOGLE_CLIENT_ID/SECRET, GOOGLE_MAP_API, OPENAI_API_KEY/
#   BASE_URL/MODEL, TWILIO_*, SERVAM_*, RAZORPAY_*, SHIPROCKET_*.
# =====================================================================
