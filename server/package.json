{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json && node scripts/copy-email-templates.js",
    "start": "node -r ./dist/tracing.js dist/index.js",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration --runInBand",
    "test:e2e": "jest --selectProjects e2e --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "migrate:user-schema": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-user-schema.ts",
    "migrate:user-schema:dry": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-user-schema.ts --dry-run",
    "sync:user-indexes": "ts-node -r tsconfig-paths/register --transpile-only scripts/sync-user-indexes.ts",
    "sync:user-indexes:dry": "ts-node -r tsconfig-paths/register --transpile-only scripts/sync-user-indexes.ts --dry-run",
    "migrate:user-schema:rollback": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-user-schema-rollback.ts",
    "migrate:rbac-roles": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-rbac-roles.ts",
    "migrate:rbac-roles:dry": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-rbac-roles.ts --dry-run",
    "migrate:survey-scope": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-survey-scope.ts",
    "migrate:survey-scope:dry": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-survey-scope.ts --dry-run",
    "migrate:host-categories": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-host-categories.ts",
    "migrate:host-categories:dry": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-host-categories.ts --dry-run",
    "migrate:product-ownership": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-product-ownership.ts",
    "migrate:product-ownership:dry": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-product-ownership.ts --dry-run",
    "migrate:email-logo": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-email-logo.ts",
    "migrate:email-logo:dry": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-email-logo.ts --dry-run",
    "migrate:verification-cleanup": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-verification-cleanup.ts",
    "migrate:verification-cleanup:dry": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-verification-cleanup.ts --dry-run",
    "migrate:bouncer-ticket-no": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-bouncer-ticket-no.ts",
    "migrate:bouncer-ticket-no:dry": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-bouncer-ticket-no.ts --dry-run",
    "migrate:club-location": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-club-location.ts",
    "migrate:club-location:dry": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-club-location.ts --dry-run"
  },
  "dependencies": {
    "@apollo/server": "^4.10.4",
    "@ngrok/ngrok": "^1.7.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.1",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "jsonwebtoken": "^9.0.2",
    "mjml": "^4.15.3",
    "mongoose": "^8.4.0",
    "nodemailer": "^6.9.13",
    "pdfkit": "^0.18.0",
    "qrcode": "1.5.4",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/typescript": "^4.0.6",
    "@graphql-codegen/typescript-resolvers": "^4.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^29",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mjml": "^4.7.4",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^6.4.15",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "1.5.5",
    "@types/supertest": "^6",
    "@types/web-push": "^3.6.4",
    "graphql-request": "^6",
    "jest": "^29",
    "mongodb-memory-server": "^9",
    "supertest": "^7",
    "ts-jest": "^29",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
