<mjml>
  <mj-head>
    <mj-title>Update on your Duncit host request</mj-title>
    <mj-attributes>
      <mj-all font-family="Inter, Helvetica, Arial, sans-serif" />
      <mj-text color="#222222" font-size="14px" line-height="22px" />
      <mj-button background-color="#3b82f6" color="#ffffff" border-radius="8px" font-weight="700" />
    </mj-attributes>
  </mj-head>
  <mj-body background-color="#f4f4f4">
    <mj-section padding="20px 0 0 0">
      <mj-column>
        <mj-image src="https://duncit.com/duncit-logo.svg" alt="Duncit" width="160px" align="center" padding="0" />
      </mj-column>
    </mj-section>
    <mj-section background-color="#ffffff" padding="20px">
      <mj-column>
        <mj-text font-size="22px" font-weight="bold" color="#222">
          Request update
        </mj-text>
        <mj-text font-size="14px" color="#555">
          Hi {{host_name}}, thank you for your interest in hosting a new category. After review, we're unable to approve your request at this time.
        </mj-text>
        <mj-text font-size="14px" color="#555">
          Request ID: <strong>{{request_no}}</strong><br />
          Category: <strong>{{category_path}}</strong>
        </mj-text>
        <mj-text font-size="13px" color="#888">
          {{reviewer_notes}}
        </mj-text>
      </mj-column>
    </mj-section>
    <mj-section padding="16px 0 24px 0">
      <mj-column>
        <mj-text align="center" font-size="12px" color="#888888">&copy; Duncit. You're receiving this because you applied to host a new category on Duncit.</mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
