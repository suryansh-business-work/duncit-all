{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "jest"],
    "paths": {
      "@config/*": ["src/config/*"],
      "@services/*": ["src/services/*"],
      "@utils/*": ["src/utils/*"],
      "@middleware/*": ["src/middleware/*"],
      "@realtime/*": ["src/realtime/*"],
      "@generated/*": ["src/generated/*"],
      "@modules/*": ["src/modules/*"],
      "@modules": ["src/modules/index.ts"],
      "@context": ["src/context.ts"],
      "@test/*": ["test/*"]
    }
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
