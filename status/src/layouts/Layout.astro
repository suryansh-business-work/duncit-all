---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Live status of every Duncit service.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/duncit-logo.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <script>
      // Ship console errors to SignOz (via the server /logs ingest).
      import { configureLogs, httpTransport, captureConsole, logs } from '@duncit/logs';
      configureLogs(httpTransport(import.meta.env.PROD ? 'https://server.duncit.com/logs' : 'http://localhost:2001/logs'));
      captureConsole(logs.website.status);
    </script>
  </body>
</html>
