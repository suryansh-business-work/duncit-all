---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Live status of every Duncit service.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/duncit-logo.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #0a0d16;
        --panel: rgba(255, 255, 255, 0.04);
        --border: rgba(255, 255, 255, 0.1);
        --ink: #eef2f7;
        --muted: #94a3b8;
        --brand: #ff5a5a;
        --ok: #22c55e;
        --down: #ef4444;
        --pending: #f59e0b;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: 'Nunito', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        background:
          radial-gradient(1200px 600px at 80% -10%, rgba(255, 90, 90, 0.16), transparent 60%),
          radial-gradient(1000px 500px at 0% 0%, rgba(56, 120, 255, 0.12), transparent 55%),
          var(--bg);
        color: var(--ink);
        min-height: 100dvh;
      }
      a { color: inherit; text-decoration: none; }
    </style>
  </head>
  <body>
    <slot />
      <script>
      // Ship console errors to SignOz (via the server /logs ingest).
      import { configureLogs, httpTransport, captureConsole, logs } from '@duncit/logs';
      configureLogs(httpTransport(import.meta.env.PROD ? 'https://server.duncit.com/logs' : 'http://localhost:2001/logs'));
      captureConsole(logs.website.status);
    </script>
  </body>
</html>
