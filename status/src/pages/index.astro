---
import Layout from '../layouts/Layout.astro';
import { groups } from '../data/services';
---

<Layout title="Duncit Status">
  <main class="mx-auto max-w-[1040px] px-5 pb-16 pt-8 sm:pt-14">
    <header class="mb-9 flex flex-wrap items-center justify-between gap-4">
      <div class="flex items-center gap-3.5">
        <img src="/duncit-logo.svg" alt="Duncit" width="40" height="40" class="rounded-lg" />
        <div>
          <h1 class="text-2xl font-black tracking-tight sm:text-[2.1rem]">Duncit Status</h1>
          <p class="mt-1 text-sm text-muted">Live availability of every Duncit console, the API and our websites.</p>
        </div>
      </div>
      <div class="inline-flex items-center gap-2.5 rounded-full border border-line bg-panel px-4 py-2.5 font-bold" id="overall">
        <span class="dot dot-pending" id="overall-dot"></span>
        <span id="overall-text">Checking services…</span>
      </div>
    </header>

    {groups.map((group) => (
      <section class="mb-8">
        <h2 class="mb-3.5 text-xs font-bold uppercase tracking-[0.12em] text-muted">{group.title}</h2>
        <div class="grid gap-3.5 [grid-template-columns:repeat(auto-fill,minmax(240px,1fr))]">
          {group.items.map((s) => (
            <div
              class="flex flex-col gap-1.5 rounded-2xl border border-line bg-panel p-4 transition duration-150 hover:-translate-y-0.5 hover:border-brand/50"
              data-url={s.probe ?? s.url}
            >
              <div class="flex items-center justify-between gap-2">
                <a class="font-extrabold hover:underline" href={s.url} target="_blank" rel="noopener">{s.name}</a>
                <span class="badge badge-pending"><span class="dot dot-pending"></span><span class="label">Checking</span></span>
              </div>
              <span class="text-sm text-muted">{s.description}</span>
              <div class="mt-1 flex items-center justify-between gap-2">
                <span class="font-mono text-[0.72rem] text-slate-500">{new URL(s.url).host}</span>
                <button
                  type="button"
                  class="cursor-pointer rounded-full border border-line bg-white/5 px-2.5 py-1 text-[0.72rem] font-extrabold transition hover:border-brand/50 hover:bg-brand/15"
                  data-name={s.name}
                  data-url={s.url}
                  data-health={s.health ?? ''}
                  aria-label={`Show status and details for ${s.name}`}
                >ⓘ Details</button>
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}

    <footer class="mt-7 flex justify-between border-t border-line pt-4 text-sm text-muted">
      <span>Refreshes automatically every 60s.</span>
      <span id="updated"></span>
    </footer>
  </main>

  <dialog
    id="detail"
    class="m-auto w-[min(480px,92vw)] rounded-2xl border border-line bg-panel p-0 text-ink shadow-2xl backdrop:bg-black/70 backdrop:backdrop-blur-sm"
  >
    <div class="flex items-center justify-between border-b border-line px-5 py-4">
      <div class="flex items-center gap-2.5">
        <span class="dot dot-pending" id="detail-dot"></span>
        <h3 class="text-lg font-black" id="detail-title">Service</h3>
      </div>
      <button type="button" class="cursor-pointer rounded-md px-1 text-2xl leading-none text-muted hover:text-ink" id="detail-close" aria-label="Close details">×</button>
    </div>
    <div id="detail-body" class="px-5 py-4"></div>
  </dialog>

  <script>
    import { runStatusPage } from '../scripts/client';
    runStatusPage();
  </script>
</Layout>
