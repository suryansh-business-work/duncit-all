---
import { siteConfig } from '../config/site-config';
const { hero } = siteConfig;
---

<section class="relative overflow-hidden">
  <div
    class="pointer-events-none absolute -top-24 right-0 h-96 w-96 rounded-full bg-primary-light blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div class="mx-auto max-w-6xl px-5 py-20 text-center sm:py-28">
    <span class="inline-block rounded-full bg-primary-light px-4 py-1 text-sm font-bold text-primary-dark">
      {hero.eyebrow}
    </span>
    <h1 class="mx-auto mt-6 max-w-3xl text-4xl text-ink sm:text-6xl">
      {hero.heading}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-ink-soft">
      {hero.subheading}
    </p>
    <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
      <a
        href={hero.primaryCta.href}
        class="rounded-full bg-primary px-7 py-3 text-base font-bold text-white shadow-lg shadow-primary/30 transition hover:bg-primary-dark"
      >
        {hero.primaryCta.label}
      </a>
      <a
        href={hero.secondaryCta.href}
        class="rounded-full border border-ink/15 px-7 py-3 text-base font-bold text-ink transition hover:border-ink/30"
      >
        {hero.secondaryCta.label}
      </a>
    </div>
  </div>
</section>
