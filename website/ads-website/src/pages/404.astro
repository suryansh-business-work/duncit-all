---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { siteConfig } from '../config/site-config';
---

<Layout title={`Page not found — ${siteConfig.brand.name}`}>
  <SiteHeader />
  <main class="mx-auto flex max-w-3xl flex-col items-center px-5 py-28 text-center">
    <span class="font-head text-7xl font-extrabold text-primary">404</span>
    <h1 class="mt-4 text-3xl text-ink">This page wandered off.</h1>
    <p class="mt-3 text-ink-soft">The page you’re looking for doesn’t exist or has moved.</p>
    <a
      href="/"
      class="mt-8 rounded-full bg-primary px-7 py-3 font-bold text-white transition hover:bg-primary-dark"
    >
      Back home
    </a>
  </main>
  <SiteFooter />
</Layout>
