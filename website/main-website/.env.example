# Duncit duncit.com — Astro marketing site (dev port 2000)
#
# Cross-site + API URLs are baked into the bundle at build time. Leaving them
# blank uses the in-code production defaults; set PUBLIC_IS_DEVELOPMENT=true
# locally to switch every default to http://localhost. CI passes the real
# values as build-args (see .github/workflows/deploy.yml).

# true = use localhost defaults for local dev.
PUBLIC_IS_DEVELOPMENT=false

PUBLIC_GRAPHQL_URL=
PUBLIC_SITE_URL=
PUBLIC_MWEB_URL=
PUBLIC_PARTNERS_SITE_URL=
PUBLIC_ADS_SITE_URL=
PUBLIC_EARNWITH_URL=
