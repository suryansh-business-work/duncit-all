---
// Shared footer used across all pages. Link columns come from the Website
// portal (Navigation manager) and the Policy Hub column from the Legal
// portal's active policies — both baked in at build time with safe fallbacks.
import { fetchBranding, fetchNavGroups, fetchPolicies } from '../lib/site-data';

const branding = await fetchBranding();
const footerLogo = branding.website_footer_logo_url || '/duncit-logo.svg';

const FALLBACK_COLUMNS = [
  {
    label: 'About',
    links: [
      { id: 'f-about', label: 'About us', url: '/about' },
      { id: 'f-newsroom', label: 'Newsroom', url: '/newsroom' },
      { id: 'f-careers', label: 'Careers', url: '/careers' },
      { id: 'f-contact', label: 'Contact us', url: '/contact' },
    ],
  },
  {
    label: 'Community',
    links: [
      { id: 'f-community', label: 'Community', url: '/community' },
      { id: 'f-guidelines', label: 'Guidelines', url: '/guidelines' },
      { id: 'f-blog', label: 'Blog', url: '/blog' },
    ],
  },
  {
    label: 'Safety Hub',
    links: [
      { id: 'f-approach', label: 'Our approach', url: '/safety/approach' },
      { id: 'f-advice', label: 'Advice', url: '/safety/advice' },
      { id: 'f-tools', label: 'Safety Tools', url: '/safety/tools' },
      { id: 'f-resources', label: 'Resources', url: '/safety/resources' },
    ],
  },
  {
    label: 'Support',
    links: [
      { id: 'f-help', label: 'Help Center', url: '/help' },
      { id: 'f-faq', label: 'FAQ', url: '/faq' },
      { id: 'f-support-mail', label: 'Email support', url: `mailto:${branding.support_email}` },
    ],
  },
];

const columns = await fetchNavGroups('MAIN', 'FOOTER', FALLBACK_COLUMNS as never);
const policies = await fetchPolicies();
const year = new Date().getFullYear();
---

<footer class="bg-cream rounded-3xl mt-3 pt-16 pb-8 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-8 items-center">
      <a href="/" class="inline-block">
        <img src={footerLogo} alt={branding.app_name} class="h-16 sm:h-24 w-auto" />
      </a>
      <div class="md:text-right">
        <p class="font-head font-bold text-ink mb-3">Get Duncit updates</p>
        <form class="flex gap-2 md:justify-end" id="footerForm">
          <input
            type="email"
            required
            placeholder="Email address"
            class="flex-1 md:flex-none md:w-64 px-4 py-2.5 rounded-lg bg-white border-2 border-ink/10 focus:border-primary outline-none text-sm"
          />
          <button class="px-4 py-2.5 rounded-lg bg-ink text-white font-bold text-sm inline-flex items-center gap-2">
            <i class="fa-solid fa-paper-plane"></i> Notify
          </button>
        </form>
      </div>
    </div>

    <hr class="my-10 border-ink/10" />

    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      {
        columns.map((column) => (
          <div>
            <h4 class="font-head font-extrabold mb-3">{column.label}</h4>
            <ul class="space-y-2 text-sm text-ink-soft">
              {column.links.map((link) => (
                <li>
                  <a href={link.url} class="hover:text-primary">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
      <div>
        <h4 class="font-head font-extrabold mb-3">Policy Hub</h4>
        <ul class="space-y-2 text-sm text-ink-soft">
          {
            policies.map((policy) => (
              <li>
                <a href={`/policy?slug=${policy.slug}`} class="hover:text-primary">
                  {policy.title}
                </a>
              </li>
            ))
          }
          <li><a href="/policies" class="hover:text-primary font-bold">All policies</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-ink/10 flex justify-center items-center text-sm text-ink-soft">
      <span>© {branding.app_name} {year} | All Rights Reserved</span>
    </div>
  </div>
</footer>

<script>
  import { urlConfigs } from '../config/url-configs';

  const GQL_URL = urlConfigs.graphqlUrl;
  const ff = document.getElementById('footerForm') as HTMLFormElement | null;
  ff?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = ff.querySelector('input[type="email"]') as HTMLInputElement;
    const email = input?.value?.trim();
    if (!email) return;
    const btn = ff.querySelector('button') as HTMLButtonElement | null;
    const orig = btn?.innerHTML;
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sending';
    }
    try {
      const res = await fetch(GQL_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query: 'mutation Sub($input: SubscribeNewsletterInput!) { subscribeNewsletter(input: $input) { ok message } }',
          variables: { input: { email, source: 'WEBSITE_FOOTER' } },
        }),
      });
      const json = await res.json();
      const ok = !!json?.data?.subscribeNewsletter?.ok;
      if (btn) {
        btn.innerHTML = ok
          ? '<i class="fa-solid fa-check"></i> Subscribed!'
          : '<i class="fa-solid fa-xmark"></i> Try again';
      }
      if (ok) input.value = '';
    } catch {
      if (btn) btn.innerHTML = '<i class="fa-solid fa-xmark"></i> Try again';
    } finally {
      window.setTimeout(() => {
        if (btn) {
          btn.innerHTML = orig || 'Notify';
          btn.disabled = false;
        }
      }, 2500);
    }
  });
</script>
