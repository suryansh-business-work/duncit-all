---
// Site-wide side navigation drawer, toggled by any element with
// [data-nav-toggle]. Sections come from the Website portal (Navigation
// manager); the Policy Hub group is the Legal portal's active policies.
import BrandLogo from './BrandLogo.astro';
import { fetchNavGroups, fetchPolicies } from '../lib/site-data';

const FALLBACK_GROUPS = [
  {
    label: 'About',
    links: [
      { id: 'n-about', label: 'About us', url: '/about' },
      { id: 'n-newsroom', label: 'Newsroom', url: '/newsroom' },
      { id: 'n-careers', label: 'Careers', url: '/careers' },
      { id: 'n-contact', label: 'Contact us', url: '/contact' },
    ],
  },
  {
    label: 'Community',
    links: [
      { id: 'n-community', label: 'Community', url: '/community' },
      { id: 'n-guidelines', label: 'Guidelines', url: '/guidelines' },
      { id: 'n-blog', label: 'Blog', url: '/blog' },
    ],
  },
  {
    label: 'Safety Hub',
    links: [
      { id: 'n-approach', label: 'Our approach', url: '/safety/approach' },
      { id: 'n-advice', label: 'Advice', url: '/safety/advice' },
      { id: 'n-tools', label: 'Safety Tools', url: '/safety/tools' },
      { id: 'n-resources', label: 'Resources', url: '/safety/resources' },
    ],
  },
  {
    label: 'Support',
    links: [
      { id: 'n-help', label: 'Help Center', url: '/help' },
      { id: 'n-faq', label: 'FAQ', url: '/faq' },
    ],
  },
];

const GROUP_ICONS: Record<string, string> = {
  About: 'fa-circle-info',
  Community: 'fa-people-group',
  'Safety Hub': 'fa-shield-heart',
  Support: 'fa-life-ring',
  'Policy Hub': 'fa-lock',
};

const navGroups = await fetchNavGroups('MAIN', 'HEADER', FALLBACK_GROUPS as never);
const policies = await fetchPolicies();
const sections = [
  ...navGroups.map((group) => ({
    title: group.label,
    icon: GROUP_ICONS[group.label] ?? 'fa-hashtag',
    links: group.links.map((link) => ({ href: link.url, label: link.label })),
  })),
  {
    title: 'Policy Hub',
    icon: 'fa-lock',
    links: [
      ...policies.map((policy) => ({ href: `/policy?slug=${policy.slug}`, label: policy.title })),
      { href: '/policies', label: 'All policies' },
    ],
  },
];
---

<!-- Backdrop -->
<div
  id="navBackdrop"
  class="fixed inset-0 z-40 bg-ink/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<!-- Drawer -->
<aside
  id="siteNav"
  class="fixed top-0 left-0 z-50 h-full w-[88%] max-w-md bg-cream shadow-2xl -translate-x-full transition-transform duration-300 flex flex-col"
  aria-hidden="true"
>
  <div class="flex items-center justify-between p-5 border-b border-ink/10">
    <BrandLogo height={38} />
    <button
      data-nav-close
      class="w-10 h-10 rounded-full bg-ink text-white inline-flex items-center justify-center hover:bg-primary transition"
      aria-label="Close menu"
    >
      <i class="fa-solid fa-xmark text-lg"></i>
    </button>
  </div>

  <nav class="flex-1 overflow-y-auto p-5 space-y-6">
    {sections.map((section) => (
      <div>
        <h4 class="flex items-center gap-2 text-xs uppercase tracking-wider font-extrabold text-ink-soft mb-2">
          <i class={`fa-solid ${section.icon} text-primary`}></i>
          {section.title}
        </h4>
        <ul class="space-y-1">
          {section.links.map((link) => (
            <li>
              <a
                href={link.href}
                class="flex items-center justify-between px-3 py-2.5 rounded-lg text-ink hover:bg-primary/10 hover:text-primary font-semibold transition group"
              >
                <span>{link.label}</span>
                <i class="fa-solid fa-arrow-right text-xs opacity-0 group-hover:opacity-100 transition"></i>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>

  <div class="p-5 border-t border-ink/10 bg-white">
    <a
      href="/#download"
      class="w-full inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-ink text-white font-bold text-sm hover:bg-primary transition"
    >
      <i class="fa-solid fa-download"></i> Get the Duncit app
    </a>
  </div>
</aside>

<!--
  Inline + dependency-free on purpose: the drawer toggle must never break if
  another bundled script on the page throws. Delegated click handling so any
  [data-nav-toggle] (homepage hero, sub-page headers) opens it.
-->
<script is:inline>
  (function () {
    var nav = document.getElementById('siteNav');
    var backdrop = document.getElementById('navBackdrop');
    if (!nav) return;
    function open() {
      nav.classList.remove('-translate-x-full');
      nav.setAttribute('aria-hidden', 'false');
      if (backdrop) {
        backdrop.classList.remove('opacity-0', 'pointer-events-none');
        backdrop.classList.add('opacity-100');
      }
      document.body.style.overflow = 'hidden';
    }
    function close() {
      nav.classList.add('-translate-x-full');
      nav.setAttribute('aria-hidden', 'true');
      if (backdrop) {
        backdrop.classList.add('opacity-0', 'pointer-events-none');
        backdrop.classList.remove('opacity-100');
      }
      document.body.style.overflow = '';
    }
    document.addEventListener('click', function (e) {
      var t = e.target;
      if (!t || !t.closest) return;
      if (t.closest('[data-nav-toggle]')) {
        e.preventDefault();
        open();
      } else if (t.closest('[data-nav-close]') || t === backdrop) {
        close();
      }
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') close();
    });
  })();
</script>
