---
import { urlConfigs } from '../config/url-configs';

interface Props {
  type: 'CAREERS' | 'NEWSROOM' | 'BLOG';
  variant?: 'jobs' | 'news' | 'cards';
}

const { type, variant = 'cards' } = Astro.props;
const graphqlUrl = urlConfigs.graphqlUrl;
---

<div
  class="not-prose my-6"
  data-website-content-list
  data-type={type}
  data-variant={variant}
  data-graphql-url={graphqlUrl}
>
  {
    variant === 'cards' ? (
      <div class="grid sm:grid-cols-2 gap-5" aria-hidden="true">
        <div class="skeleton h-64" />
        <div class="skeleton h-64" />
        <div class="skeleton h-64" />
        <div class="skeleton h-64" />
      </div>
    ) : (
      <div class="space-y-3" aria-hidden="true">
        <div class="skeleton h-24" />
        <div class="skeleton h-24" />
        <div class="skeleton h-24" />
      </div>
    )
  }
</div>

<!-- Apply-to-role dialog (careers pages only; opened per role). -->
<dialog
  id="applyDialog"
  class="m-auto w-[92%] max-w-lg rounded-3xl p-0 backdrop:bg-ink/60 backdrop:backdrop-blur-sm"
>
  <form id="applyForm" method="dialog" class="bg-cream p-6 rounded-3xl">
    <div class="flex items-start justify-between gap-3 mb-4">
      <div>
        <p class="text-xs uppercase tracking-wider font-extrabold text-primary">Apply for</p>
        <h3 class="font-head font-extrabold text-2xl text-ink" id="applyRoleTitle">Role</h3>
      </div>
      <button
        type="button"
        data-apply-close
        class="w-9 h-9 rounded-full bg-ink text-white inline-flex items-center justify-center hover:bg-primary transition"
        aria-label="Close"
      >
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <div class="space-y-3">
      <input name="name" required minlength="2" maxlength="120" placeholder="Full name *" class="w-full px-4 py-2.5 rounded-lg bg-white border-2 border-ink/10 focus:border-primary outline-none text-sm" />
      <input name="email" type="email" required maxlength="254" placeholder="Email *" class="w-full px-4 py-2.5 rounded-lg bg-white border-2 border-ink/10 focus:border-primary outline-none text-sm" />
      <input name="phone" pattern="\+?\d{6,15}" placeholder="Phone (digits, optional +)" class="w-full px-4 py-2.5 rounded-lg bg-white border-2 border-ink/10 focus:border-primary outline-none text-sm" />
      <input name="resume_url" type="url" placeholder="Resume / CV link (Drive, LinkedIn…)" class="w-full px-4 py-2.5 rounded-lg bg-white border-2 border-ink/10 focus:border-primary outline-none text-sm" />
      <input name="portfolio_url" type="url" placeholder="Portfolio link (optional)" class="w-full px-4 py-2.5 rounded-lg bg-white border-2 border-ink/10 focus:border-primary outline-none text-sm" />
      <textarea name="cover_note" rows="3" maxlength="4000" placeholder="Why you? (optional)" class="w-full px-4 py-2.5 rounded-lg bg-white border-2 border-ink/10 focus:border-primary outline-none text-sm"></textarea>
      <p id="applyFeedback" class="text-sm font-semibold hidden"></p>
      <button type="submit" class="w-full px-4 py-3 rounded-xl bg-primary text-white font-bold inline-flex items-center justify-center gap-2 sticker hover:scale-[1.01] transition">
        <i class="fa-solid fa-paper-plane"></i> Submit application
      </button>
    </div>
  </form>
</dialog>

<script>
  import { urlConfigs } from '../config/url-configs';

  const query = `
    query PublicWebsiteContent($type: WebsitePageType!) {
      publicWebsiteContent(type: $type) {
        id
        title
        slug
        summary
        body
        category
        image_url
        cta_label
        cta_url
        published_at
      }
    }
  `;

  const escapeHtml = (value: unknown) => String(value || '')
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');

  const safeUrl = (value: unknown) => {
    const raw = String(value || '').trim();
    if (!raw) return '#';
    if (/^(mailto:|tel:)/i.test(raw)) return raw;
    try {
      const parsed = new URL(raw);
      return ['http:', 'https:'].includes(parsed.protocol) ? parsed.toString() : '#';
    } catch {
      return '#';
    }
  };

  const formatDate = (value: unknown) => {
    if (!value) return '';
    try {
      return new Intl.DateTimeFormat('en', { month: 'short', day: '2-digit', year: 'numeric' })
        .format(new Date(String(value)));
    } catch {
      return '';
    }
  };

  const graphQlUrlFor = (root: HTMLElement) => {
    if (root.dataset.graphqlUrl) return root.dataset.graphqlUrl;
    return urlConfigs.graphqlUrl;
  };

  // Open roles: an Apply button per role opens the application dialog —
  // submissions land in the Website portal's Job Applications inbox.
  const renderJobs = (items: any[]) => `
    <div class="space-y-3">
      ${items.map((item) => `
        <div class="p-5 rounded-2xl bg-white sticker">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="font-head font-bold text-ink text-lg">${escapeHtml(item.title)}</div>
              <div class="text-sm text-ink-soft mt-1">${escapeHtml(item.category || item.summary)}</div>
              ${item.body ? `<p class="text-sm text-ink-soft mt-2">${escapeHtml(item.body)}</p>` : ''}
            </div>
            <button type="button" data-apply-role data-role-id="${escapeHtml(item.id)}" data-role-title="${escapeHtml(item.title)}"
              class="px-4 py-2 rounded-full bg-primary text-white font-bold text-xs uppercase tracking-wider sticker shrink-0 hover:scale-105 transition">
              Apply now
            </button>
          </div>
        </div>
      `).join('')}
    </div>`;

  const renderNews = (items: any[]) => `
    <div class="space-y-4">
      ${items.map((item) => `
        <a href="${safeUrl(item.cta_url)}" class="flex items-center gap-4 p-5 rounded-2xl bg-white sticker hover:-translate-y-0.5 transition">
          <div class="w-12 h-12 rounded-xl bg-secondary/15 text-secondary inline-flex items-center justify-center shrink-0">
            <i class="fa-solid fa-newspaper text-lg"></i>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 text-xs text-ink-soft mb-1">
              <span class="font-bold uppercase tracking-wider text-primary">${escapeHtml(item.category)}</span>
              <span>${item.category && item.published_at ? '•' : ''}</span>
              <span>${escapeHtml(formatDate(item.published_at))}</span>
            </div>
            <div class="font-head font-bold text-ink">${escapeHtml(item.title)}</div>
            ${item.summary ? `<p class="text-sm text-ink-soft mt-1">${escapeHtml(item.summary)}</p>` : ''}
          </div>
          <i class="fa-solid fa-arrow-right text-ink-soft"></i>
        </a>
      `).join('')}
    </div>`;

  // Blog cards open the on-site blog detail page (suggested/related/archive).
  const renderCards = (items: any[]) => `
    <div class="grid sm:grid-cols-2 gap-5">
      ${items.map((item) => `
        <a href="/blog/post?slug=${encodeURIComponent(item.slug)}" class="block bg-white rounded-2xl overflow-hidden sticker hover:-translate-y-1 transition">
          ${item.image_url ? `<img src="${safeUrl(item.image_url)}" alt="" class="w-full aspect-video object-cover" />` : ''}
          <div class="p-5">
            <div class="flex items-center gap-2 text-xs text-ink-soft mb-2">
              <span class="font-bold uppercase tracking-wider text-primary">${escapeHtml(item.category)}</span>
              <span>${item.category && item.published_at ? '•' : ''}</span>
              <span>${escapeHtml(formatDate(item.published_at))}</span>
            </div>
            <h3 class="font-head font-bold text-ink text-lg leading-snug">${escapeHtml(item.title)}</h3>
            ${item.summary ? `<p class="text-sm text-ink-soft mt-2">${escapeHtml(item.summary)}</p>` : ''}
          </div>
        </a>
      `).join('')}
    </div>`;

  const RENDERERS: Record<string, (items: any[]) => string> = {
    jobs: renderJobs,
    news: renderNews,
    cards: renderCards,
  };

  document.querySelectorAll<HTMLElement>('[data-website-content-list]').forEach(async (root) => {
    try {
      const response = await fetch(graphQlUrlFor(root), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query, variables: { type: root.dataset.type } }),
      });
      const payload = await response.json();
      if (payload.errors?.length) throw new Error(payload.errors[0].message);
      const items = payload.data?.publicWebsiteContent || [];
      if (!items.length) {
        root.innerHTML = '<div class="p-5 rounded-2xl bg-white sticker text-ink-soft">No published items yet.</div>';
        return;
      }
      const render = RENDERERS[root.dataset.variant ?? 'cards'] ?? renderCards;
      root.innerHTML = render(items);
    } catch (error) {
      root.innerHTML = '<div class="p-5 rounded-2xl bg-white sticker text-ink-soft">Content is temporarily unavailable.</div>';
    }
  });

  // ---- Apply dialog wiring ----
  const dialog = document.getElementById('applyDialog') as HTMLDialogElement | null;
  const applyForm = document.getElementById('applyForm') as HTMLFormElement | null;
  const roleTitleEl = document.getElementById('applyRoleTitle');
  const feedback = document.getElementById('applyFeedback');
  let activeRole: { id: string; title: string } | null = null;

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement | null;
    const trigger = target?.closest?.('[data-apply-role]') as HTMLElement | null;
    if (trigger && dialog) {
      activeRole = { id: trigger.dataset.roleId ?? '', title: trigger.dataset.roleTitle ?? 'Role' };
      if (roleTitleEl) roleTitleEl.textContent = activeRole.title;
      if (feedback) feedback.classList.add('hidden');
      applyForm?.reset();
      dialog.showModal();
    }
    if (target?.closest?.('[data-apply-close]')) dialog?.close();
  });

  applyForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!applyForm.reportValidity() || !activeRole) return;
    const data = new FormData(applyForm);
    const submitBtn = applyForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sending…';
    }
    try {
      const res = await fetch(urlConfigs.graphqlUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query:
            'mutation Apply($input: SubmitJobApplicationInput!) { submitJobApplication(input: $input) { ok message } }',
          variables: {
            input: {
              role_content_id: activeRole.id || null,
              role_title: activeRole.title,
              name: data.get('name'),
              email: data.get('email'),
              phone: data.get('phone') || '',
              resume_url: data.get('resume_url') || '',
              portfolio_url: data.get('portfolio_url') || '',
              cover_note: data.get('cover_note') || '',
            },
          },
        }),
      });
      const json = await res.json();
      const result = json?.data?.submitJobApplication;
      if (feedback) {
        feedback.classList.remove('hidden');
        if (result?.ok) {
          feedback.textContent = result.message || 'Application received!';
          feedback.className = 'text-sm font-semibold text-green-700';
          window.setTimeout(() => dialog?.close(), 1800);
        } else {
          feedback.textContent = json?.errors?.[0]?.message || 'Could not submit — please check the form.';
          feedback.className = 'text-sm font-semibold text-primary';
        }
      }
    } catch {
      if (feedback) {
        feedback.classList.remove('hidden');
        feedback.textContent = 'Network hiccup — please try again.';
        feedback.className = 'text-sm font-semibold text-primary';
      }
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Submit application';
      }
    }
  });
</script>
