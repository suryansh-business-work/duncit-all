---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Duncit — connect instantly with friends who match your energy.',
} = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/duncit-logo.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@700;800&family=Plus+Jakarta+Sans:wght@600;700;800;900&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
  </head>
  <body>
    <slot />
      <script>
      // Ship console errors to SignOz (via the server /logs ingest).
      import { configureLogs, httpTransport, captureConsole, logs } from '@duncit/logs';
      configureLogs(httpTransport(import.meta.env.PROD ? 'https://server.duncit.com/logs' : 'http://localhost:2001/logs'));
      captureConsole(logs.website.duncit);
    </script>
  </body>
</html>
