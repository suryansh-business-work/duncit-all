---
import PageLayout from '../layouts/PageLayout.astro';
import WebsiteContentList from '../components/WebsiteContentList.astro';
---

<PageLayout
  title="Careers"
  eyebrow="We're hiring"
  heading="Build Duncit with us"
  intro="Join a small, mission-driven team building the next generation of friendship."
  accent="tertiary"
  heroImage="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1600&q=80&auto=format&fit=crop"
>
  <h2>Why Duncit?</h2>
  <ul>
    <li>Fully remote-first, with optional hubs in Berlin & NYC</li>
    <li>Competitive equity and salary</li>
    <li>Unlimited PTO (with a 4-week minimum)</li>
    <li>Annual company offsite — last one was in Lisbon</li>
    <li>Mental health & wellness stipend</li>
  </ul>

  <h2>Open roles</h2>
  <WebsiteContentList type="CAREERS" variant="jobs" />

  <h2>Don't see your role?</h2>
  <p>
    We love hearing from talented people. Send us a note at
    <a href="mailto:careers@duncit.com">careers@duncit.com</a> and tell us what you'd build.
  </p>
</PageLayout>
