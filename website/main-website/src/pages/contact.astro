---
// Contact — reach-us cards come from Admin branding (support email/phone) and
// the form lands in the Website portal's Contact Submissions inbox.
import PageLayout from '../layouts/PageLayout.astro';
import { fetchBranding } from '../lib/site-data';

const branding = await fetchBranding();
const supportEmail = branding.support_email || 'support@duncit.com';
const supportPhone = branding.support_phone;
---

<PageLayout
  title="Contact us"
  eyebrow="Say hi"
  heading="Get in touch"
  intro="Questions, partnerships, press, or just a friendly hello — we'd love to hear from you."
  accent="secondary"
  heroImage="https://images.unsplash.com/photo-1573497019418-b400bb3ab074?w=1600&q=80&auto=format&fit=crop"
>
  <div class="not-prose grid sm:grid-cols-2 gap-4 my-6">
    <a href={`mailto:${supportEmail}`} class="block p-5 rounded-2xl glass hover:-translate-y-0.5 transition text-center">
      <i class="fa-solid fa-envelope text-2xl text-primary mb-2" aria-hidden="true"></i>
      <div class="font-head font-bold text-ink">Email us</div>
      <div class="text-sm text-ink-soft mt-1">{supportEmail}</div>
    </a>
    {supportPhone ? (
      <a href={`tel:${supportPhone}`} class="block p-5 rounded-2xl glass hover:-translate-y-0.5 transition text-center">
        <i class="fa-solid fa-phone text-2xl text-secondary mb-2" aria-hidden="true"></i>
        <div class="font-head font-bold text-ink">Call us</div>
        <div class="text-sm text-ink-soft mt-1">{supportPhone}</div>
      </a>
    ) : (
      <a href="/help" class="block p-5 rounded-2xl glass hover:-translate-y-0.5 transition text-center">
        <i class="fa-solid fa-life-ring text-2xl text-tertiary-dark mb-2" aria-hidden="true"></i>
        <div class="font-head font-bold text-ink">Help Center</div>
        <div class="text-sm text-ink-soft mt-1">Browse answered topics</div>
      </a>
    )}
  </div>

  <h2>Send us a message</h2>
  <form class="not-prose grid gap-4 max-w-xl mt-4" id="contactForm">
    <input name="name" required placeholder="Your name" class="px-4 py-3 rounded-xl bg-white border-2 border-ink/10 focus:border-primary outline-none" />
    <input name="email" required type="email" placeholder="Your email" class="px-4 py-3 rounded-xl bg-white border-2 border-ink/10 focus:border-primary outline-none" />
    <input name="subject" placeholder="Subject (optional)" class="px-4 py-3 rounded-xl bg-white border-2 border-ink/10 focus:border-primary outline-none" />
    <textarea name="message" required rows="5" placeholder="What's on your mind?" class="px-4 py-3 rounded-xl bg-white border-2 border-ink/10 focus:border-primary outline-none resize-y"></textarea>
    <p id="contactErr" class="text-sm text-red-600 hidden"></p>
    <button class="px-6 py-3.5 rounded-xl bg-ink text-white font-bold sticker hover:-translate-y-0.5 transition inline-flex items-center justify-center gap-2 self-start">
      Send <i class="fa-solid fa-paper-plane"></i>
    </button>
  </form>
</PageLayout>

<script>
  import { urlConfigs } from '../config/url-configs';

  const GQL_URL = urlConfigs.graphqlUrl;
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const errBox = document.getElementById('contactErr') as HTMLParagraphElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errBox) {
      errBox.classList.add('hidden');
      errBox.textContent = '';
    }
    const fd = new FormData(form);
    const payload = {
      name: String(fd.get('name') || '').trim(),
      email: String(fd.get('email') || '').trim(),
      subject: String(fd.get('subject') || '').trim(),
      message: String(fd.get('message') || '').trim(),
    };
    const btn = form.querySelector('button') as HTMLButtonElement | null;
    const orig = btn?.innerHTML;
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sending';
    }
    try {
      const res = await fetch(GQL_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query:
            'mutation Submit($input: SubmitContactInput!) { submitContactForm(input: $input) { ok message } }',
          variables: { input: payload },
        }),
      });
      const json = await res.json();
      if (json?.errors?.length) throw new Error(json.errors[0].message);
      if (!json?.data?.submitContactForm?.ok) throw new Error('Could not send. Try again.');
      if (btn) btn.innerHTML = '<i class="fa-solid fa-check"></i> Message sent!';
      form.reset();
    } catch (err: any) {
      if (errBox) {
        errBox.classList.remove('hidden');
        errBox.textContent = err?.message || 'Could not send. Please try again.';
      }
      if (btn) btn.innerHTML = orig || 'Send';
    } finally {
      window.setTimeout(() => {
        if (btn) {
          btn.disabled = false;
          if (!btn.innerHTML.includes('check')) btn.innerHTML = orig || 'Send';
        }
      }, 3000);
    }
  });
</script>
