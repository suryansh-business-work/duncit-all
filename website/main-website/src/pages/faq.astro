---
// FAQs load client-side from the Support portal so new answers appear
// without a redeploy; the support email comes from Admin branding.
import PageLayout from '../layouts/PageLayout.astro';
import { fetchBranding } from '../lib/site-data';

const branding = await fetchBranding();
const supportEmail = branding.support_email || 'support@duncit.com';
---

<PageLayout
  title="FAQ"
  eyebrow="Support"
  heading="Frequently Asked"
  intro="Quick answers to the questions we hear most."
  accent="tertiary"
  heroImage="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=1600&q=80&auto=format&fit=crop"
>
  <div id="faqGroups" class="not-prose my-6 space-y-3">
    <div class="skeleton h-8 w-48" aria-hidden="true"></div>
    <div class="skeleton h-20" aria-hidden="true"></div>
    <div class="skeleton h-20" aria-hidden="true"></div>
    <div class="skeleton h-20" aria-hidden="true"></div>
  </div>

  <h2>Didn't find your answer?</h2>
  <p>Ask us directly — if it's a common one, we'll add it to this page.</p>
  <form class="not-prose grid gap-3 max-w-xl mt-4" id="askFaqForm">
    <textarea
      name="question"
      required
      rows="3"
      placeholder="Type your question…"
      class="px-4 py-3 rounded-xl bg-white border-2 border-ink/10 focus:border-primary outline-none resize-y"
    ></textarea>
    <input
      name="email"
      type="email"
      required
      placeholder="Email for a reply"
      class="px-4 py-3 rounded-xl bg-white border-2 border-ink/10 focus:border-primary outline-none"
    />
    <p id="askFaqErr" class="text-sm text-red-600 hidden"></p>
    <button class="px-6 py-3 rounded-xl bg-ink text-white font-bold sticker hover:-translate-y-0.5 transition inline-flex items-center justify-center gap-2 self-start">
      Ask <i class="fa-solid fa-paper-plane"></i>
    </button>
  </form>
  <p class="mt-4">Or email <a href={`mailto:${supportEmail}`}>{supportEmail}</a>.</p>
</PageLayout>

<script>
  import { urlConfigs } from '../config/url-configs';

  const GQL_URL = urlConfigs.graphqlUrl;
  const groupsEl = document.getElementById('faqGroups');

  const esc = (value: unknown) => {
    const div = document.createElement('div');
    div.textContent = String(value ?? '');
    return div.innerHTML;
  };

  const faqCard = (faq: any, open: boolean) => `
    <details class="group bg-white rounded-2xl p-5 sticker"${open ? ' open' : ''}>
      <summary class="flex items-center justify-between cursor-pointer list-none gap-4">
        <span class="font-head font-bold text-ink">${esc(faq.question)}</span>
        <i class="fa-solid fa-plus text-primary transition group-open:rotate-45" aria-hidden="true"></i>
      </summary>
      <p class="mt-3 text-ink-soft whitespace-pre-line">${esc(faq.answer)}</p>
    </details>`;

  async function loadFaqs() {
    if (!groupsEl) return;
    try {
      const res = await fetch(GQL_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query:
            'query { publicFaqGroups { super_category { id name slug } faqs { id question answer } } }',
        }),
      });
      const json = await res.json();
      const groups: any[] = (json?.data?.publicFaqGroups ?? []).filter((g: any) => g.faqs?.length);
      if (!groups.length) {
        groupsEl.innerHTML =
          '<p class="text-ink-soft">No FAQs published yet — ask your question below and we\'ll answer.</p>';
        return;
      }
      groupsEl.innerHTML = groups
        .map((group) => {
          const heading = group.super_category
            ? `<h2 id="${esc(group.super_category.slug)}" class="font-head font-extrabold text-2xl mt-8 mb-3 text-primary scroll-mt-24">${esc(group.super_category.name)}</h2>`
            : '';
          const cards = group.faqs.map((faq: any, index: number) => faqCard(faq, index === 0)).join('');
          return `<section class="my-6">${heading}<div class="space-y-3">${cards}</div></section>`;
        })
        .join('');
      // Honour a #slug deep-link (e.g. from the Help Center topic cards) now
      // that the anchored headings exist in the DOM.
      const hash = window.location.hash.slice(1);
      if (hash) document.getElementById(decodeURIComponent(hash))?.scrollIntoView({ behavior: 'smooth' });
    } catch {
      groupsEl.innerHTML =
        '<p class="text-ink-soft">FAQs could not be loaded right now. Please try again later.</p>';
    }
  }

  loadFaqs();

  const form = document.getElementById('askFaqForm') as HTMLFormElement | null;
  const errBox = document.getElementById('askFaqErr') as HTMLParagraphElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errBox) {
      errBox.classList.add('hidden');
      errBox.textContent = '';
    }
    const fd = new FormData(form);
    const payload = {
      question: String(fd.get('question') || '').trim(),
      email: String(fd.get('email') || '').trim(),
    };
    if (payload.question.length < 5) {
      if (errBox) {
        errBox.classList.remove('hidden');
        errBox.textContent = 'Please type a longer question.';
      }
      return;
    }
    if (!payload.email) {
      if (errBox) {
        errBox.classList.remove('hidden');
        errBox.textContent = 'Please enter your email.';
      }
      return;
    }
    const btn = form.querySelector('button') as HTMLButtonElement | null;
    const orig = btn?.innerHTML;
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sending';
    }
    try {
      const res = await fetch(GQL_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query:
            'mutation Ask($input: SubmitFaqQuestionInput!) { submitFaqQuestion(input: $input) { ok message } }',
          variables: { input: payload },
        }),
      });
      const json = await res.json();
      if (json?.errors?.length) throw new Error(json.errors[0].message);
      if (!json?.data?.submitFaqQuestion?.ok) throw new Error('Could not send. Try again.');
      if (btn) btn.innerHTML = '<i class="fa-solid fa-check"></i> Got it!';
      form.reset();
    } catch (err: any) {
      if (errBox) {
        errBox.classList.remove('hidden');
        errBox.textContent = err?.message || 'Could not send. Please try again.';
      }
      if (btn) btn.innerHTML = orig || 'Ask';
    } finally {
      window.setTimeout(() => {
        if (btn) {
          btn.disabled = false;
          if (!btn.innerHTML.includes('check')) btn.innerHTML = orig || 'Ask';
        }
      }, 3000);
    }
  });
</script>
