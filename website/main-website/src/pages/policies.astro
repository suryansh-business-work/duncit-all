---
// Policy Hub — every active policy from the Legal portal. Fetched in the
// browser so newly published policies appear without a site redeploy.
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Policy Hub"
  eyebrow="Policy Hub"
  heading="Duncit policies"
  intro="Every policy that governs Duncit, published live from our Legal team — always the current version."
  heroImage="https://images.unsplash.com/photo-1487058792275-0ad4aaf24ca7?w=1600&q=80&auto=format&fit=crop"
>
  <div id="policyList" class="not-prose grid sm:grid-cols-2 gap-4">
    <div class="skeleton h-28" aria-hidden="true"></div>
    <div class="skeleton h-28" aria-hidden="true"></div>
    <div class="skeleton h-28" aria-hidden="true"></div>
    <div class="skeleton h-28" aria-hidden="true"></div>
  </div>
</PageLayout>

<script>
  import { urlConfigs } from '../config/url-configs';

  const target = document.getElementById('policyList');

  function esc(value: string) {
    const div = document.createElement('div');
    div.textContent = value ?? '';
    return div.innerHTML;
  }

  async function load() {
    if (!target) return;
    try {
      const res = await fetch(urlConfigs.graphqlUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: 'query { publicPolicies { id slug title } }' }),
      });
      const json = await res.json();
      const policies: { slug: string; title: string }[] = json?.data?.publicPolicies ?? [];
      if (!policies.length) {
        target.innerHTML =
          '<p class="text-ink-soft col-span-full">No policies are published yet — check back soon.</p>';
        return;
      }
      target.innerHTML = policies
        .map(
          (policy) => `
            <a href="/policy?slug=${encodeURIComponent(policy.slug)}"
               class="glass rounded-2xl p-5 flex items-center justify-between gap-3 hover:-translate-y-0.5 transition">
              <span>
                <span class="block font-head font-extrabold text-lg text-ink">${esc(policy.title)}</span>
                <span class="block text-xs text-ink-soft mt-1">Read the current version</span>
              </span>
              <i class="fa-solid fa-arrow-right text-primary" aria-hidden="true"></i>
            </a>`
        )
        .join('');
    } catch {
      target.innerHTML =
        '<p class="text-ink-soft col-span-full">Policies could not be loaded right now. Please try again later.</p>';
    }
  }

  load();
</script>
