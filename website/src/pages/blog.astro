---
import PageLayout from '../layouts/PageLayout.astro';

const posts = [
  { date: 'Apr 14, 2026', title: 'How we designed Duncit\'s vibe-matching algorithm', cat: 'Engineering', img: 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=600&q=80&auto=format&fit=crop' },
  { date: 'Apr 02, 2026', title: '5 ways to break the ice without being cringe', cat: 'Tips', img: 'https://images.unsplash.com/photo-1529390079861-591de354faf5?w=600&q=80&auto=format&fit=crop' },
  { date: 'Mar 21, 2026', title: 'Loneliness is a design problem. Here\'s our take.', cat: 'Essay', img: 'https://images.unsplash.com/photo-1516589178581-6cd7833ae3b2?w=600&q=80&auto=format&fit=crop' },
  { date: 'Mar 05, 2026', title: 'Inside the Duncit beta: weeks 1–4', cat: 'Product', img: 'https://images.unsplash.com/photo-1543807535-eceef0bc6599?w=600&q=80&auto=format&fit=crop' },
  { date: 'Feb 18, 2026', title: 'Hosting your first IRL meetup: a tiny playbook', cat: 'Community', img: 'https://images.unsplash.com/photo-1496440737103-cd596325d314?w=600&q=80&auto=format&fit=crop' },
  { date: 'Feb 02, 2026', title: 'Why we\'re building safety in from day one', cat: 'Safety', img: 'https://images.unsplash.com/photo-1521791136064-7986c2920216?w=600&q=80&auto=format&fit=crop' },
];
---

<PageLayout
  title="Blog"
  eyebrow="Notes & stories"
  heading="The Duncit Blog"
  intro="Product updates, design notes, friendship research, and the occasional rant."
  accent="secondary"
  heroImage="https://images.unsplash.com/photo-1455390582262-044cdead277a?w=1600&q=80&auto=format&fit=crop"
>
  <div class="not-prose grid sm:grid-cols-2 gap-5 my-6">
    {posts.map((p) => (
      <a href="#" class="block bg-white rounded-2xl overflow-hidden sticker hover:-translate-y-1 transition">
        <img src={p.img} alt="" class="w-full aspect-video object-cover" />
        <div class="p-5">
          <div class="flex items-center gap-2 text-xs text-ink-soft mb-2">
            <span class="font-bold uppercase tracking-wider text-primary">{p.cat}</span>
            <span>•</span>
            <span>{p.date}</span>
          </div>
          <h3 class="font-head font-bold text-ink text-lg leading-snug">{p.title}</h3>
        </div>
      </a>
    ))}
  </div>

  <h2>Subscribe</h2>
  <p>Get one short email a week. No spam, just the good stuff. <a href="/">Join the list →</a></p>
</PageLayout>
