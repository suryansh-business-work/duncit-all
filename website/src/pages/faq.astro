---
import PageLayout from '../layouts/PageLayout.astro';

// FAQs are loaded dynamically from the GraphQL server at build time so that
// content stays fresh as the admin team publishes new entries. We fall back
// to an empty list if the server is unreachable.
const GQL_URL = import.meta.env.PUBLIC_GRAPHQL_URL || 'https://server.duncit.com/graphql';

interface Faq {
  id: string;
  question: string;
  answer: string;
}

interface FaqGroup {
  super_category: { id: string; name: string; slug: string } | null;
  faqs: Faq[];
}

let groups: FaqGroup[] = [];
try {
  const res = await fetch(GQL_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      query: `query { publicFaqGroups { super_category { id name slug } faqs { id question answer } } }`,
    }),
  });
  const json = await res.json();
  groups = (json?.data?.publicFaqGroups ?? []) as FaqGroup[];
} catch {
  groups = [];
}
---

<PageLayout
  title="FAQ"
  eyebrow="Support"
  heading="Frequently Asked"
  intro="Quick answers to the questions we hear most."
  accent="tertiary"
  heroImage="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=1600&q=80&auto=format&fit=crop"
>
  {groups.length === 0 && (
    <p class="text-ink-soft my-6">Don't see your question? Submit it below and we'll add it.</p>
  )}

  {groups.map((group) => (
    <section class="my-6">
      {group.super_category && (
        <h2 class="font-head font-extrabold text-2xl mt-8 mb-3 text-primary">
          {group.super_category.name}
        </h2>
      )}
      <div class="not-prose space-y-3">
        {group.faqs.map((f, i) => (
          <details
            class="group bg-white rounded-2xl p-5 sticker"
            {...(i === 0 ? { open: true } : {})}
          >
            <summary class="flex items-center justify-between cursor-pointer list-none gap-4">
              <span class="font-head font-bold text-ink">{f.question}</span>
              <i class="fa-solid fa-plus text-primary transition group-open:rotate-45"></i>
            </summary>
            <p class="mt-3 text-ink-soft whitespace-pre-line">{f.answer}</p>
          </details>
        ))}
      </div>
    </section>
  ))}

  <h2>Didn't find your answer?</h2>
  <p>Ask us directly — if it's a common one, we'll add it to this page.</p>
  <form class="not-prose grid gap-3 max-w-xl mt-4" id="askFaqForm">
    <textarea
      name="question"
      required
      rows="3"
      placeholder="Type your question…"
      class="px-4 py-3 rounded-xl bg-white border-2 border-ink/10 focus:border-primary outline-none resize-y"
    ></textarea>
    <input
      name="email"
      type="email"
      required
      placeholder="Email for a reply"
      class="px-4 py-3 rounded-xl bg-white border-2 border-ink/10 focus:border-primary outline-none"
    />
    <p id="askFaqErr" class="text-sm text-red-600 hidden"></p>
    <button class="px-6 py-3 rounded-xl bg-ink text-white font-bold sticker hover:-translate-y-0.5 transition inline-flex items-center justify-center gap-2 self-start">
      Ask <i class="fa-solid fa-paper-plane"></i>
    </button>
  </form>
  <p class="mt-4">Or email <a href="mailto:support@duncit.com">support@duncit.com</a>.</p>
</PageLayout>

<script>
  const GQL_URL = (import.meta as any).env?.PUBLIC_GRAPHQL_URL || 'https://server.duncit.com/graphql';
  const form = document.getElementById('askFaqForm') as HTMLFormElement | null;
  const errBox = document.getElementById('askFaqErr') as HTMLParagraphElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errBox) {
      errBox.classList.add('hidden');
      errBox.textContent = '';
    }
    const fd = new FormData(form);
    const payload = {
      question: String(fd.get('question') || '').trim(),
      email: String(fd.get('email') || '').trim(),
    };
    if (payload.question.length < 5) {
      if (errBox) {
        errBox.classList.remove('hidden');
        errBox.textContent = 'Please type a longer question.';
      }
      return;
    }
    if (!payload.email) {
      if (errBox) {
        errBox.classList.remove('hidden');
        errBox.textContent = 'Please enter your email.';
      }
      return;
    }
    const btn = form.querySelector('button') as HTMLButtonElement | null;
    const orig = btn?.innerHTML;
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sending';
    }
    try {
      const res = await fetch(GQL_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query:
            'mutation Ask($input: SubmitFaqQuestionInput!) { submitFaqQuestion(input: $input) { ok message } }',
          variables: { input: payload },
        }),
      });
      const json = await res.json();
      if (json?.errors?.length) throw new Error(json.errors[0].message);
      if (!json?.data?.submitFaqQuestion?.ok) throw new Error('Could not send. Try again.');
      if (btn) btn.innerHTML = '<i class="fa-solid fa-check"></i> Got it!';
      form.reset();
    } catch (err: any) {
      if (errBox) {
        errBox.classList.remove('hidden');
        errBox.textContent = err?.message || 'Could not send. Please try again.';
      }
      if (btn) btn.innerHTML = orig || 'Ask';
    } finally {
      window.setTimeout(() => {
        if (btn) {
          btn.disabled = false;
          if (!btn.innerHTML.includes('check')) btn.innerHTML = orig || 'Ask';
        }
      }, 3000);
    }
  });
</script>
