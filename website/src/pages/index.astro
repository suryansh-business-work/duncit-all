---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import BrandLogo from '../components/BrandLogo.astro';
import { urlConfigs } from '../config/url-configs';

// Real group photos from Unsplash (free to use)
const comingSoonImg = 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1600&q=80&auto=format&fit=crop';
const vibesImg = 'https://images.unsplash.com/photo-1543269865-cbf427effbad?w=1200&q=80&auto=format&fit=crop';
const flow1 = 'https://images.unsplash.com/photo-1543807535-eceef0bc6599?w=600&q=80&auto=format&fit=crop';
const flow2 = 'https://images.unsplash.com/photo-1529390079861-591de354faf5?w=600&q=80&auto=format&fit=crop';
const flow3 = 'https://images.unsplash.com/photo-1523580494863-6f3031224c94?w=600&q=80&auto=format&fit=crop';
const flow4 = 'https://images.unsplash.com/photo-1496440737103-cd596325d314?w=600&q=80&auto=format&fit=crop';
const mwebLoginUrl = `${urlConfigs.mwebUrl}/login`;
const mwebRegisterUrl = `${urlConfigs.mwebUrl}/register`;
const earningPaths = [
  {
    icon: 'fa-store',
    title: 'Register your venue',
    text: 'Host the party at your place and Duncit will provide verified bookings for your available slots.',
    href: '/register-your-venue',
  },
  {
    icon: 'fa-champagne-glasses',
    title: 'Be a Host',
    text: 'Host bankar paisa kamao: create pods, bring the right people together, and grow with Duncit.',
    href: '/be-a-host',
  },
];
---

<Layout title="Duncit — Friends who match your energy">
  <SiteNav />
  <div class="bg-ink p-3 sm:p-4">
    <!-- ============== HERO ============== -->
    <section class="relative overflow-hidden rounded-3xl min-h-[640px] px-6 pt-5 pb-8">
      <!-- Background reel (muted, looping, autoplay) with overlay -->
      <div class="absolute inset-0 z-0">
        <video
          class="w-full h-full object-cover"
          poster="/media/duncit-reel-poster.jpg"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
        >
          <source src="/media/duncit-reel.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-gradient-to-b from-sky-300/40 via-transparent to-ink/30"></div>
      </div>

      <!-- Marquee ribbon running around the banner border (transparent, 12px bold) -->
      <svg
        id="bannerMarquee"
        class="absolute inset-0 z-10 pointer-events-none overflow-visible"
        preserveAspectRatio="none"
        aria-hidden="true"
      >
        <defs><path id="bannerMarqueePath" fill="none"></path></defs>
        <text
          id="bannerMarqueeText"
          style="font-family:'Plus Jakarta Sans',system-ui,sans-serif;font-size:12px;font-weight:700;letter-spacing:0.06em;fill:rgba(255,255,255,0.92);"
        >
          <textPath id="bannerMarqueeTextPath" href="#bannerMarqueePath" startOffset="0"></textPath>
        </text>
      </svg>

      <!-- Nav -->
      <nav class="relative z-20 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <button data-nav-toggle class="w-11 h-11 rounded-full bg-ink text-white inline-flex items-center justify-center hover:scale-105 transition" aria-label="Menu">
            <i class="fa-solid fa-bars text-lg"></i>
          </button>
          <BrandLogo height={40} />
        </div>
        <div class="flex items-center gap-2">
          <a href={mwebLoginUrl} class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-tertiary text-ink text-xs font-bold sticker hover:scale-105 transition">
            <i class="fa-solid fa-bolt"></i> mWeb is Live
          </a>
          <a href="#" class="w-11 h-11 rounded-full bg-ink text-white inline-flex items-center justify-center hover:scale-105 transition" aria-label="App Store">
            <i class="fa-brands fa-apple text-lg"></i>
          </a>
          <a href="#" class="w-11 h-11 rounded-full bg-ink text-white inline-flex items-center justify-center hover:scale-105 transition" aria-label="Google Play">
            <i class="fa-brands fa-google-play text-base"></i>
          </a>
        </div>
      </nav>

      <!-- Stage: the looping reel speaks for itself — just the calls to action. -->
      <div class="relative z-10 h-[480px] flex flex-col items-center justify-end pb-6 gap-3 sm:flex-row">
        <a
          href={mwebRegisterUrl}
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-primary text-white font-bold text-base sticker hover:scale-[1.03] transition"
        >
          <i class="fa-solid fa-bolt"></i> Join the energy
        </a>
        <a
          href={mwebLoginUrl}
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-white/90 backdrop-blur text-ink font-bold text-base sticker hover:scale-[1.03] transition"
        >
          <i class="fa-solid fa-right-to-bracket"></i> Sign in
        </a>
      </div>
    </section>

    <!-- ============== MOBILE WEB - LIVE NOW ============== -->
    <section class="bg-cream py-20 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 text-primary font-bold text-xs uppercase tracking-wider mb-6">
          <i class="fa-solid fa-bolt"></i> Live now
        </span>
        <h2 class="text-4xl sm:text-5xl md:text-6xl mb-4">
          Mobile Web app is <span class="text-primary">accessible</span>
        </h2>
        <p class="text-ink-soft text-lg max-w-xl mx-auto mb-8">
          Sign in from any browser — no install required. The full Duncit
          experience runs on your phone right now.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
          <a
            href={mwebLoginUrl}
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-primary text-white font-bold text-base sticker hover:scale-[1.03] transition"
          >
            <i class="fa-solid fa-right-to-bracket"></i> Sign in to launch
          </a>
          <a
            href={mwebRegisterUrl}
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-ink/5 text-ink font-bold text-base hover:bg-ink/10 transition"
          >
            <i class="fa-solid fa-user-plus"></i> Create an account
          </a>
        </div>
      </div>
    </section>

    <!-- ============== MOBILE APPS PREVIEW ============== -->
    <section class="relative overflow-hidden py-20 px-6">
      <!-- Background image with overlay -->
      <div class="absolute inset-0 z-0">
        <img src={comingSoonImg} alt="" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-linear-to-br from-secondary/85 via-ink/80 to-primary/85"></div>
      </div>

      <div class="relative z-10 max-w-5xl mx-auto text-center">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-tertiary text-ink font-bold text-xs uppercase tracking-wider mb-6 sticker">
          <i class="fa-solid fa-mobile-screen"></i> Mobile App
        </span>
        <h2 class="text-4xl sm:text-5xl md:text-6xl mb-4 text-white">
          Native app <span class="text-tertiary">in the works</span>
        </h2>
        <p class="text-white/85 text-lg max-w-xl mx-auto mb-6">
          Meanwhile, our Mobile Web app (mWeb) is live — sign in below and
          launch Duncit right from your browser. iOS &amp; Android apps land soon.
        </p>

        <!-- Live mWeb CTA -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center items-center mb-10">
          <a
            href={mwebLoginUrl}
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-tertiary text-ink font-bold text-base sticker hover:scale-[1.03] transition"
          >
            <i class="fa-solid fa-right-to-bracket"></i> Sign in to launch mWeb
          </a>
          <a
            href={mwebRegisterUrl}
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-white/10 backdrop-blur text-white font-bold text-base border border-white/30 hover:bg-white/20 transition"
          >
            <i class="fa-solid fa-user-plus"></i> Create an account
          </a>
        </div>

        <!-- App store preview cards -->
        <div class="grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
          <div class="bg-ink text-white rounded-2xl p-6 sticker relative overflow-hidden">
            <span class="absolute top-3 right-3 px-2.5 py-1 rounded-full bg-tertiary text-ink text-[10px] font-black uppercase tracking-wider">Soon</span>
            <i class="fa-brands fa-apple text-5xl mb-3"></i>
            <div class="text-left">
              <div class="text-xs opacity-70 uppercase tracking-wide">Coming to the</div>
              <div class="text-xl font-bold font-head">App Store</div>
            </div>
          </div>
          <div class="bg-ink text-white rounded-2xl p-6 sticker relative overflow-hidden">
            <span class="absolute top-3 right-3 px-2.5 py-1 rounded-full bg-tertiary text-ink text-[10px] font-black uppercase tracking-wider">Soon</span>
            <i class="fa-brands fa-google-play text-5xl mb-3"></i>
            <div class="text-left">
              <div class="text-xs opacity-70 uppercase tracking-wide">Coming to</div>
              <div class="text-xl font-bold font-head">Google Play</div>
            </div>
          </div>
        </div>

        <!-- Feature checklist -->
        <div data-reveal-group class="mt-12 grid sm:grid-cols-3 gap-6 max-w-3xl mx-auto text-left">
          <div data-reveal class="bg-white/95 backdrop-blur rounded-2xl p-5 sticker">
            <div class="w-10 h-10 rounded-full bg-primary/15 text-primary inline-flex items-center justify-center mb-3">
              <i class="fa-solid fa-bolt"></i>
            </div>
            <h3 class="text-lg mb-1">Instant matches</h3>
            <p class="text-sm text-ink-soft">Swipe into vibe-based friend circles in seconds.</p>
          </div>
          <div data-reveal class="bg-white/95 backdrop-blur rounded-2xl p-5 sticker">
            <div class="w-10 h-10 rounded-full bg-secondary/15 text-secondary inline-flex items-center justify-center mb-3">
              <i class="fa-solid fa-comments"></i>
            </div>
            <h3 class="text-lg mb-1">Real chats</h3>
            <p class="text-sm text-ink-soft">No pressure, just real talk and laughs.</p>
          </div>
          <div data-reveal class="bg-white/95 backdrop-blur rounded-2xl p-5 sticker">
            <div class="w-10 h-10 rounded-full bg-tertiary/30 text-tertiary-dark inline-flex items-center justify-center mb-3">
              <i class="fa-solid fa-shield-heart"></i>
            </div>
            <h3 class="text-lg mb-1">Safe space</h3>
            <p class="text-sm text-ink-soft">Verified profiles and built-in safety tools.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============== WAY OF EARNINGS ============== -->
    <section class="bg-cream py-20 px-6">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-[0.8fr_1.2fr] gap-8 items-start">
        <div>
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 text-primary font-bold text-xs uppercase tracking-wider mb-5">
            <i class="fa-solid fa-coins"></i> Way of Earnings with Duncit
          </span>
          <h2 class="text-4xl sm:text-5xl md:text-6xl mb-4">Earn through real gatherings</h2>
          <p class="text-ink-soft text-lg max-w-md">
            Duncit connects earning opportunities to actual local demand: venues get bookings, hosts create experiences.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          {earningPaths.map((path) => (
            <a href={path.href} class="group bg-white rounded-3xl p-6 sticker hover:-translate-y-1 transition block">
              <div class="w-14 h-14 rounded-2xl bg-primary/10 text-primary inline-flex items-center justify-center mb-5 group-hover:bg-primary group-hover:text-white transition">
                <i class={`fa-solid ${path.icon} text-2xl`}></i>
              </div>
              <h3 class="text-2xl text-ink mb-2">{path.title}</h3>
              <p class="text-ink-soft leading-relaxed">{path.text}</p>
              <span class="inline-flex items-center gap-2 mt-5 font-bold text-primary">
                Start now <i class="fa-solid fa-arrow-right"></i>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ============== REAL VIBES ============== -->
    <section class="bg-lilac py-20 px-6">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-secondary/15 text-secondary font-bold text-xs uppercase tracking-wider mb-4">
            <i class="fa-solid fa-fire"></i> Real Energy
          </span>
          <h2 class="text-4xl sm:text-5xl md:text-6xl mb-5">
            Straight to the<br />
            <span class="text-secondary">real vibes</span>
          </h2>
          <p class="text-ink-soft text-lg max-w-md">
            Chatting effortless on Duncit. Discover what you share with new
            friends and dive right into laughs or real talk.
          </p>
          <div class="mt-6 flex gap-4 text-ink-soft">
            <span class="inline-flex items-center gap-1.5"><i class="fa-solid fa-check text-primary"></i> No bots</span>
            <span class="inline-flex items-center gap-1.5"><i class="fa-solid fa-check text-primary"></i> No fakes</span>
            <span class="inline-flex items-center gap-1.5"><i class="fa-solid fa-check text-primary"></i> Just vibes</span>
          </div>
        </div>
        <div class="relative">
          <img src={vibesImg} alt="Friends chatting" class="w-full aspect-[4/5] object-cover rounded-3xl sticker" />
          <span class="absolute -top-4 -left-4 px-4 py-2 rounded-full bg-tertiary text-ink font-bold sticker -rotate-6">
            <i class="fa-solid fa-heart text-primary"></i> Authentic
          </span>
        </div>
      </div>
    </section>

    <!-- ============== FLOW ============== -->
    <section class="bg-tertiary py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 gap-10 items-start">
          <h2 class="text-4xl sm:text-5xl md:text-6xl">
            Flow with the<br />moment
          </h2>
          <p class="text-ink font-medium text-lg max-w-md">
            Discover new friends without the pressure—see what you have in
            common, start fun or meaningful conversations, and connect naturally.
          </p>
        </div>

        <div data-reveal-group class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-4">
          <div data-reveal class="relative -translate-y-4 md:-translate-y-8">
            <img src={flow1} alt="" class="w-full aspect-[3/4] object-cover rounded-2xl sticker" />
            <span class="absolute -top-2 -left-2 px-3 py-1 rounded-full bg-tertiary text-ink font-bold text-xs sticker -rotate-12">NEON</span>
          </div>
          <div data-reveal class="relative">
            <img src={flow2} alt="" class="w-full aspect-[3/4] object-cover rounded-2xl sticker" />
            <span class="absolute -top-2 -right-2 px-3 py-1 rounded-full bg-purple-300 text-ink font-bold text-xs sticker rotate-12">YUM</span>
          </div>
          <div data-reveal class="relative -translate-y-2 md:-translate-y-6">
            <img src={flow3} alt="" class="w-full aspect-[3/4] object-cover rounded-2xl sticker" />
            <span class="absolute -top-3 -right-3 w-11 h-11 rounded-full bg-primary text-white font-bold text-xl inline-flex items-center justify-center sticker rotate-12">
              <i class="fa-solid fa-bolt"></i>
            </span>
          </div>
          <div data-reveal class="relative">
            <img src={flow4} alt="" class="w-full aspect-[3/4] object-cover rounded-2xl sticker" />
            <span class="absolute -bottom-2 -right-2 px-3 py-1 rounded-full bg-secondary text-white font-bold text-xs sticker -rotate-6">CHILL</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============== FOOTER ============== -->
    <Footer />
  </div>
</Layout>

<script>
  import { animate, stagger } from 'animejs';

  // ---------- Scroll reveals ----------
  const revealGroups = document.querySelectorAll('[data-reveal-group]');
  const io = new IntersectionObserver((entries, obs) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const items = entry.target.querySelectorAll('[data-reveal]');
      try {
        animate(items, {
          opacity: [0, 1],
          translateY: [40, 0],
          scale: [0.92, 1],
          delay: stagger(90),
          duration: 600,
          ease: 'outQuart',
        });
      } catch (e) {
        items.forEach((el) => ((el as HTMLElement).style.opacity = '1'));
      }
      obs.unobserve(entry.target);
    });
  }, { threshold: 0.15 });

  revealGroups.forEach((g) => {
    const items = g.querySelectorAll('[data-reveal]');
    items.forEach((el) => ((el as HTMLElement).style.opacity = '0'));
    io.observe(g);
  });

  // ---------- Email capture (stores locally — wire to your API later) ----------
  function handleSubmit(formId: string, inputId?: string) {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    if (!form) return;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = inputId
        ? (document.getElementById(inputId) as HTMLInputElement)
        : (form.querySelector('input[type="email"]') as HTMLInputElement);
      const email = input?.value?.trim();
      if (!email) return;
      const list = JSON.parse(localStorage.getItem('duncit_emails') || '[]');
      if (!list.includes(email)) {
        list.push(email);
        localStorage.setItem('duncit_emails', JSON.stringify(list));
      }
      input.value = '';
      const ok = document.getElementById('successMsg');
      if (formId === 'emailForm' && ok) {
        form.classList.add('hidden');
        ok.classList.remove('hidden');
        ok.classList.add('inline-flex');
        animate(ok, {
          scale: [0.7, 1.05, 1],
          opacity: [0, 1],
          duration: 500,
          ease: 'outBack(1.4)',
        });
      } else {
        const btn = form.querySelector('button');
        if (btn) {
          const orig = btn.innerHTML;
          btn.innerHTML = '<i class="fa-solid fa-check"></i> Got it!';
          setTimeout(() => { btn.innerHTML = orig; }, 2500);
        }
      }
    });
  }
  handleSubmit('footerForm');

  // ---------- Banner perimeter marquee ----------
  (function bannerMarquee() {
    const svg = document.getElementById('bannerMarquee') as unknown as SVGSVGElement | null;
    const path = document.getElementById('bannerMarqueePath') as unknown as SVGPathElement | null;
    const textEl = document.getElementById('bannerMarqueeText') as unknown as SVGTextElement | null;
    const tp = document.getElementById('bannerMarqueeTextPath');
    if (!svg || !path || !textEl || !tp) return;

    const MSG =
      'Real people. Real energy.  Sports, live music, nightlife, the outdoors — see what happens when the right people match your energy.  •  ';
    let unitLen = 0;
    let offset = 0;
    let raf = 0;

    function build() {
      const r = svg!.getBoundingClientRect();
      const w = Math.round(r.width);
      const h = Math.round(r.height);
      if (!w || !h) return;
      svg!.setAttribute('viewBox', `0 0 ${w} ${h}`);
      const i = 9;
      const rad = 22;
      path!.setAttribute(
        'd',
        `M ${i + rad},${i} H ${w - i - rad} A ${rad},${rad} 0 0 1 ${w - i},${i + rad} V ${h - i - rad} A ${rad},${rad} 0 0 1 ${w - i - rad},${h - i} H ${i + rad} A ${rad},${rad} 0 0 1 ${i},${h - i - rad} V ${i + rad} A ${rad},${rad} 0 0 1 ${i + rad},${i} Z`,
      );
      const pathLen = path!.getTotalLength();
      tp!.textContent = MSG;
      unitLen = textEl!.getComputedTextLength() || MSG.length * 7;
      const copies = Math.max(2, Math.ceil((pathLen + unitLen) / unitLen) + 1);
      tp!.textContent = MSG.repeat(copies);
    }

    function tick() {
      offset -= 0.5; // px/frame — slow, ambient drift
      if (unitLen && offset <= -unitLen) offset += unitLen; // seamless wrap
      tp!.setAttribute('startOffset', String(offset));
      raf = requestAnimationFrame(tick);
    }

    function start() {
      build();
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(tick);
    }

    const fonts = (document as any).fonts;
    if (fonts?.ready) fonts.ready.then(start);
    else start();

    let rt: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(build, 150);
    });
  })();
</script>
