---
import PageLayout from '../layouts/PageLayout.astro';

const PARTNERS_URL = 'https://partners.duncit.com';

const steps = [
  {
    n: '01',
    icon: 'fa-shop',
    title: 'List your venue',
    desc: 'Café, bar, studio, lounge, rooftop — share photos, capacity, vibe and what makes it yours.',
  },
  {
    n: '02',
    icon: 'fa-clipboard-check',
    title: 'Get verified',
    desc: 'Quick verification of business details and address. Trusted venues get the Duncit blue tick.',
  },
  {
    n: '03',
    icon: 'fa-calendar-week',
    title: 'Set availability',
    desc: 'Pick the slots you want filled — quiet weekday afternoons, themed nights, anything.',
  },
  {
    n: '04',
    icon: 'fa-users-viewfinder',
    title: 'Hosts book your space',
    desc: 'Verified Duncit hosts discover your venue and request slots that match their hangout vibe.',
  },
  {
    n: '05',
    icon: 'fa-handshake',
    title: 'Welcome the crowd',
    desc: 'Real groups walk in. No flakes, no chaos — every guest is ID-verified and confirmed.',
  },
  {
    n: '06',
    icon: 'fa-chart-line',
    title: 'Grow your bookings',
    desc: 'Track footfall, repeat customers, and revenue from your Partners dashboard.',
  },
];

const perks = [
  { icon: 'fa-store', title: 'Fill empty slots', desc: 'Turn quiet hours into buzzing hangouts with curated, vibe-matched groups.' },
  { icon: 'fa-shield-check', title: 'Zero-flake guests', desc: 'Every attendee is verified. RSVPs are real. Your kitchen plans accurately.' },
  { icon: 'fa-percent', title: 'No platform fees*', desc: 'Founding venues join free. *During launch period.' },
  { icon: 'fa-chart-pie', title: 'Insights dashboard', desc: 'See peak demand, group sizes, repeat hosts and what hangouts work best for you.' },
];

const venueTypes = [
  { icon: 'fa-mug-hot', label: 'Cafés' },
  { icon: 'fa-martini-glass-citrus', label: 'Bars & Lounges' },
  { icon: 'fa-utensils', label: 'Restaurants' },
  { icon: 'fa-music', label: 'Live music' },
  { icon: 'fa-gamepad', label: 'Game cafés' },
  { icon: 'fa-bowling-ball', label: 'Activity venues' },
  { icon: 'fa-building', label: 'Co-working' },
  { icon: 'fa-tree-city', label: 'Rooftops' },
];
---

<PageLayout
  title="Register Your Venue"
  eyebrow="Become a partner venue"
  heading="Bring real crowds to your space"
  intro="Partner with Duncit to turn quiet slots into curated hangouts. Verified hosts, vibe-matched guests, zero-flake bookings."
  accent="secondary"
  heroImage="https://images.unsplash.com/photo-1554118811-1e0d58224f24?w=1600&q=80&auto=format&fit=crop"
>
  <!-- Big CTA -->
  <div class="not-prose mb-12">
    <div class="rounded-3xl bg-ink text-white p-8 sm:p-10 sticker">
      <div class="flex flex-col sm:flex-row sm:items-center gap-6 justify-between">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-secondary text-white font-bold text-xs uppercase tracking-wider sticker mb-3">
            <i class="fa-solid fa-rocket"></i> Founding venues — free
          </div>
          <h2 class="font-head font-black text-2xl sm:text-3xl text-white m-0">
            List your venue in 5 minutes.
          </h2>
          <p class="text-white/70 mt-2 m-0">Sign up on our Partners portal to get started.</p>
        </div>
        <a
          href={PARTNERS_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-6 py-4 rounded-full bg-secondary text-white font-head font-bold text-lg sticker hover:-translate-y-0.5 transition shrink-0"
        >
          Register Your Venue
          <i class="fa-solid fa-arrow-up-right-from-square"></i>
        </a>
      </div>
    </div>
  </div>

  <!-- Venue types -->
  <h2>What kind of venues we partner with</h2>
  <div class="not-prose mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
    {venueTypes.map((v) => (
      <div class="p-4 rounded-2xl bg-white sticker text-center">
        <i class={`fa-solid ${v.icon} text-secondary text-2xl`}></i>
        <div class="font-head font-bold text-ink text-sm mt-2">{v.label}</div>
      </div>
    ))}
  </div>

  <!-- Flow -->
  <h2 class="mt-16">How partnering with Duncit works</h2>
  <p>From listing to your first booked hangout — six steps, fully guided.</p>

  <div class="not-prose mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {steps.map((s, i) => (
      <div class="relative p-6 rounded-2xl bg-white sticker hover:-translate-y-1 transition">
        <div class="absolute -top-3 -left-3 w-12 h-12 rounded-full bg-secondary text-white inline-flex items-center justify-center font-head font-black text-lg sticker">
          {s.n}
        </div>
        <div class="w-12 h-12 rounded-xl bg-cream inline-flex items-center justify-center mb-3 ml-10">
          <i class={`fa-solid ${s.icon} text-secondary text-xl`}></i>
        </div>
        <h3 class="font-head font-black text-ink text-lg m-0">{s.title}</h3>
        <p class="text-ink-soft text-sm mt-2 m-0">{s.desc}</p>
        {i < steps.length - 1 && (
          <div class="hidden lg:block absolute top-1/2 -right-3 text-secondary text-2xl z-10">
            <i class="fa-solid fa-arrow-right"></i>
          </div>
        )}
      </div>
    ))}
  </div>

  <!-- Visual flow strip -->
  <div class="not-prose mt-10 p-6 rounded-3xl bg-lilac/50">
    <div class="font-head font-bold text-ink text-sm uppercase tracking-wider mb-4 inline-flex items-center gap-2">
      <i class="fa-solid fa-route text-secondary"></i> Your venue journey
    </div>
    <div class="flex flex-wrap items-center gap-3">
      <span class="px-4 py-2 rounded-full bg-white sticker font-bold text-ink text-sm"><i class="fa-solid fa-shop text-secondary mr-1"></i> List</span>
      <i class="fa-solid fa-arrow-right text-ink/40"></i>
      <span class="px-4 py-2 rounded-full bg-white sticker font-bold text-ink text-sm"><i class="fa-solid fa-clipboard-check text-secondary mr-1"></i> Verify</span>
      <i class="fa-solid fa-arrow-right text-ink/40"></i>
      <span class="px-4 py-2 rounded-full bg-white sticker font-bold text-ink text-sm"><i class="fa-solid fa-calendar-week text-secondary mr-1"></i> Set slots</span>
      <i class="fa-solid fa-arrow-right text-ink/40"></i>
      <span class="px-4 py-2 rounded-full bg-white sticker font-bold text-ink text-sm"><i class="fa-solid fa-users-viewfinder text-secondary mr-1"></i> Get bookings</span>
      <i class="fa-solid fa-arrow-right text-ink/40"></i>
      <span class="px-4 py-2 rounded-full bg-white sticker font-bold text-ink text-sm"><i class="fa-solid fa-handshake text-secondary mr-1"></i> Welcome guests</span>
      <i class="fa-solid fa-arrow-right text-ink/40"></i>
      <span class="px-4 py-2 rounded-full bg-secondary text-white sticker font-bold text-sm"><i class="fa-solid fa-chart-line mr-1"></i> Grow revenue</span>
    </div>
  </div>

  <!-- Perks -->
  <h2 class="mt-16">Why venues love Duncit</h2>
  <div class="not-prose mt-6 grid sm:grid-cols-2 gap-4">
    {perks.map((p) => (
      <div class="p-5 rounded-2xl bg-white sticker">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-secondary/10 inline-flex items-center justify-center shrink-0">
            <i class={`fa-solid ${p.icon} text-secondary text-xl`}></i>
          </div>
          <div>
            <h3 class="font-head font-black text-ink text-base m-0">{p.title}</h3>
            <p class="text-ink-soft text-sm mt-1 m-0">{p.desc}</p>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Final CTA -->
  <div class="not-prose mt-12">
    <a
      href={PARTNERS_URL}
      target="_blank"
      rel="noopener"
      class="block text-center p-8 rounded-3xl bg-secondary text-white sticker hover:-translate-y-1 transition"
    >
      <div class="font-head font-black text-2xl sm:text-3xl">List your venue today</div>
      <div class="text-white/85 mt-2">5-minute setup. Free for founding partners.</div>
      <div class="inline-flex items-center gap-2 mt-4 px-5 py-2.5 rounded-full bg-white text-secondary font-bold sticker">
        Go to Partners Portal <i class="fa-solid fa-arrow-up-right-from-square"></i>
      </div>
    </a>
  </div>
</PageLayout>
